---
const { headline, subtitle, cta } = Astro.props;
---

<section class="hero bg-blue-600 text-white py-20">
  <div class="container mx-auto text-center">
    <h1 class="text-5xl font-bold mb-4">{headline}</h1>
    <p class="text-xl mb-8">{subtitle}</p>
    <button class="bg-white text-blue-600 px-8 py-3 rounded-full text-lg font-semibold hover:bg-gray-100">
      {cta}
    </button>
  </div>
</section>
