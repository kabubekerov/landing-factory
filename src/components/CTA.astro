---
const { headline, description, buttonText, buttonUrl = '#contact' } = Astro.props;
---

<section class="cta py-20 bg-gradient-to-r from-blue-600 to-blue-800 text-white">
  <div class="container mx-auto text-center">
    <h2 class="text-4xl font-bold mb-4">{headline}</h2>
    <p class="text-xl mb-8 text-blue-100">{description}</p>
    <a href={buttonUrl} class="inline-block bg-white text-blue-600 px-8 py-3 rounded-full text-lg font-semibold hover:bg-gray-100 transition" onclick="window.trackCTAClick && window.trackCTAClick()">
      {buttonText}
    </a>
  </div>
</section>
