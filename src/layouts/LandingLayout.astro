---
import Hero from '../components/Hero.astro';
import Problem from '../components/Problem.astro';
import Solution from '../components/Solution.astro';
import Proof from '../components/Proof.astro';
import FAQ from '../components/FAQ.astro';
import CTA from '../components/CTA.astro';
import Form from '../components/Form.astro';
import Analytics from '../components/Analytics.astro';
import '../styles/global.css';

const { 
  headline, 
  subtitle, 
  cta,
  slug,
  problems = [],
  benefits = [],
  caseStudies = [],
  faqs = []
} = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{headline}</title>
  </head>
  <body>
    <Analytics landingSlug={slug} />
    <Hero headline={headline} subtitle={subtitle} cta={cta} />
    {problems.length > 0 && <Problem problems={problems} />}
    {benefits.length > 0 && <Solution benefits={benefits} />}
    {caseStudies.length > 0 && <Proof caseStudies={caseStudies} />}
    {faqs.length > 0 && <FAQ faqs={faqs} />}
    <CTA 
      headline="Ready to get started?" 
      description="Join hundreds of companies transforming their product development." 
      buttonText={cta}
      buttonUrl="#contact"
    />
    <Form formName={`landing-${slug}`} landingSlug={slug} />
    <slot />
  </body>
</html>
