---
import Analytics from '../components/Analytics.astro';
import '../styles/global.css';

const slug = 'vkb-gorgippiya';
const formName = 'vkb-gorgippiya-repack-request';

const images = {
  hero: 'https://d2xsxph8kpxj0f.cloudfront.net/310519663259840902/AXotyppPfFeghR67Uzfaab/offer801-hero-clean-Lqy3vDEe5JDxTYL6dn5xSm.webp',
  aha1: 'https://d2xsxph8kpxj0f.cloudfront.net/310519663259840902/AXotyppPfFeghR67Uzfaab/offer801-courtyard-clean-KqDL6AqqXYREWP6gYVxE9T.webp',
  aha2: 'https://d2xsxph8kpxj0f.cloudfront.net/310519663259840902/AXotyppPfFeghR67Uzfaab/offer801-interior-clean-iWWvJJ96yaYAh4KrVnVRRa.webp',
  aha3: 'https://d2xsxph8kpxj0f.cloudfront.net/310519663259840902/AXotyppPfFeghR67Uzfaab/offer801-green-life-clean-dUMd5Atin3umGzTBnPyXSV.webp',
  qualifier: 'https://d2xsxph8kpxj0f.cloudfront.net/310519663259840902/AXotyppPfFeghR67Uzfaab/offer801-courtyard-clean-KqDL6AqqXYREWP6gYVxE9T.webp',
  compare: 'https://d2xsxph8kpxj0f.cloudfront.net/310519663259840902/AXotyppPfFeghR67Uzfaab/offer801-green-life-clean-dUMd5Atin3umGzTBnPyXSV.webp',
  evolution: 'https://d2xsxph8kpxj0f.cloudfront.net/310519663259840902/AXotyppPfFeghR67Uzfaab/offer801-interior-clean-iWWvJJ96yaYAh4KrVnVRRa.webp',
  footer: 'https://d2xsxph8kpxj0f.cloudfront.net/310519663259840902/AXotyppPfFeghR67Uzfaab/offer801-strategy-clean-E5MfcWKwwZcEvkEZgCTEGq.webp',
  currentPositioning: '/assets/vkb-gorgippiya/original/current_positioning.webp',
};

const triggerPoints = [
  'Семья давно мечтала о море, но не хотела терять привычный уклад. Анапа — это не курортный компромисс, а полноценная жизнь у воды, с инфраструктурой, школой и парком прямо во дворе.',
  'Горгиппия — единственный в Анапе проект по системе «всё включено»: собственная школа-гимназия «Эврика», детсады, паркинги, магазины и Черноморский парк 26 га.',
  'До моря всего 1,5 км. Рядом заповедные зоны Сукко и Утриш — 15 минут от микрорайона. Это не временный переезд к морю, а постоянная жизнь в правильном месте.',
  'В какой-то момент становится ясно: можно не выбирать между качеством жизни и близостью к морю — Горгиппия даёт и то, и другое.',
];

const responseCards = [
  {
    number: '01',
    title: 'Собственная инфраструктура — не обещание, а реальность',
    problem:
      'В большинстве курортных городов семья с детьми сталкивается с одной проблемой: либо море, либо нормальная школа и детсад. Горгиппия снимает этот выбор.',
    answer:
      'Школа-гимназия «Эврика», действующий детсад, строящиеся ещё два сада на 350 и 220 мест, поликлиника, ТРЦ «Красная Площадь» рядом — это полноценная городская жизнь у моря.',
    detail:
      'Поэтому Горгиппия читается не как курортный ЖК, а как самодостаточный микрорайон, где семья не зависит от городской инфраструктуры за его пределами.',
    cta: '',
    image: images.aha1,
    alt: 'Собственная инфраструктура МКР Горгиппия в Анапе',
  },
  {
    number: '02',
    title: 'Черноморский парк 26 га — природа как часть повседневного уклада',
    problem:
      'Большинство семей, переезжающих к морю, получают либо курортный шум, либо изолированный посёлок вдали от всего. Горгиппия — другой сценарий.',
    answer:
      'Собственный Черноморский парк площадью 26 га, заповедные зоны Сукко и Утриш в 15 минутах, 1,5 км до моря — это не разовые выезды, а ежедневный фон жизни.',
    detail:
      'Так проект снимает противоречие между «жить у природы» и «жить в нормальном городе» — семья получает и то, и другое без компромиссов.',
    cta: '',
    image: images.aha2,
    alt: 'Черноморский парк и природное окружение МКР Горгиппия',
  },
  {
    number: '03',
    title: 'Система «всё включено» — редкость для российского рынка',
    problem:
      'Горгиппия — единственный в Анапе проект, возводимый по системе «всё включено»: вся социальная и инженерная инфраструктура строится вместе с жильём, а не обещается потом.',
    answer:
      'Два многоуровневых паркинга, сетевые магазины, пункты выдачи интернет-заказов, строящаяся поликлиника — это не будущее, а уже работающая среда.',
    detail:
      'Именно поэтому Горгиппия читается как выбор не ради переезда к морю, а ради более качественной и устойчивой жизни семьи на годы вперёд.',
    cta: '',
    image: images.aha3,
    alt: 'Система всё включено в МКР Горгиппия, Анапа',
  },
];

const selfSelection = [
  'Горгиппию имеет смысл переупаковывать для семей, которые давно мечтали о море, но не хотели жертвовать инфраструктурой, школой и привычным качеством жизни.',
  'Это выбор для тех, кто хочет жить у моря постоянно — не дача, не аренда на лето, а настоящий дом с парком, школой и 1,5 км до Черноморского берега.',
  'Если семья устала откладывать переезд к морю «до лучших времён» и хочет наконец сделать это правильно — этот сегмент узнаёт себя сразу.',
  'Не «квартира у моря», а самодостаточный микрорайон с инфраструктурой, парком и 1,5 км до Черноморского берега.',
  '«Не «квартира у моря», а самодостаточный микрорайон с инфраструктурой, парком и 1,5 км до Черноморского берега».',
];

const comparisons = [];

const lifeStages = [
  {
    stage: 'Стадия 01 · сначала семье важно просто иметь своё',
    price: 'JTBD / B2B view',
    who: 'На первом цикле жильё решает базовую задачу закрепления: своё пространство, понятная опора и старт семейной жизни.',
    hire: 'На этом этапе семья выбирает не зрелый сценарий, а факт собственного дома как основы нового этапа.',
    format: 'Для девелопера это базовый рынок семейного жилья, где ещё работает общий язык про метры, планировки и понятный комфорт.',
  },
  {
    stage: 'Стадия 02 · потом жизнь семьи становится сложнее и устойчивее',
    price: 'JTBD / B2B view',
    who: 'Появляются дети, школа, секции, маршруты, связи с районом и более сложная организация повседневности.',
    hire: 'С этого момента выбор жилья перестаёт быть только квартирным и становится жизненно-логистическим.',
    format: 'Именно здесь сегмент начинает отличаться от общей аудитории семей с детьми и требует более точного позиционирования.',
  },
  {
    stage: 'Стадия 03 · мечта о море откладывается снова и снова',
    price: 'JTBD / B2B view',
    who: 'Семья хочет переехать к морю, но боится потерять школу, инфраструктуру и привычное качество жизни.',
    hire: 'На языке продукта это означает: текущая упаковка должна продавать не «квартиру у моря», а снятие страха потери привычной среды.',
    format: 'Именно здесь открывается настоящий JTBD-сегмент для Горгиппии, а не просто широкая категория курортной недвижимости.',
  },
  {
    stage: 'Стадия 04 · выбор смещается с локации на способ жизни',
    price: 'JTBD / B2B view',
    who: 'Семья начинает выбирать не просто «квартиру у моря», а среду, которая способна поддерживать её уклад на долгий срок.',
    hire: 'Здесь офферу уже недостаточно говорить языком близости к пляжу: он должен собирать более зрелый жизненный переход.',
    format: 'Для CEO это точка, где продукт нужно переупаковывать вокруг новой семейной задачи, а не вокруг набора характеристик.',
  },
  {
    stage: 'Стадия 05 · Горгиппия становится не сделкой, а долгосрочной базой у моря',
    price: 'JTBD / B2B view',
    who: 'Именно здесь продукт можно переупаковать точнее: как физическую и психологическую опору семьи, которая наконец живёт у моря постоянно.',
    hire: 'Этот сдвиг и превращает «покупателей курортной недвижимости» в отдельный, более глубокий JTBD-сегмент.',
    format: 'Дальше задача ВКБ-Новостройки — перевести эту логику в оффер, страницу, креативы и аргументацию отдела продаж.',
  },
];

const processSteps = [
  {
    number: '01',
    title: 'Вы оставляете контакты и ссылку на проект',
    text: 'Показываете текущий ЖК, лендинг или рекламную коммуникацию, которая не даёт нужной конверсии.',
  },
  {
    number: '02',
    title: 'Мы собираем гипотезу переупаковки',
    text: 'Смотрим, как проект позиционируется сейчас, и находим, где сильные стороны Горгиппии остаются слишком общими или недосказанными.',
  },
  {
    number: '03',
    title: 'Проводим встречу по проекту',
    text: 'Показываем, как можно пересобрать оффер, структуру страницы, визуальные акценты и аргументацию под сегмент постоянной жизни у моря.',
  },
  {
    number: '04',
    title: 'Фиксируем следующий шаг',
    text: 'После этого определяем, что делать дальше: корректировать сегмент, перепрошивать оффер или полностью пересобирать упаковку проекта.',
  },
];
---

<html lang="ru">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>МКР «Горгиппия» — жизнь у моря с полноценной инфраструктурой в Анапе</title>
    <meta
      name="description"
      content="Показываем, как МКР «Горгиппия» можно раскрыть как постоянную жизнь у Черноморского берега: школа, парк 26 га, 1,5 км до моря и система «всё включено»."
    />
  </head>
  <body class="landing-745">
    <Analytics landingSlug={slug} />

    <main>
      <section class="hero745 section section--photo-hero">
        <div class="hero745__backdrop" style={`--section-bg: url(${images.hero})`}></div>
        <div class="container hero745__container">
          <div class="hero745__label">Анапа · Черноморское побережье · жизнь у моря</div>
          <div class="hero745__grid">
            <div class="hero745__content hero745__content--glass">
              <h1>Жизнь у Черноморского берега — не дача и не аренда, а настоящий дом</h1>
              <p class="hero745__lead">
                МКР «Горгиппия» — единственный в Анапе проект по системе «всё включено»: собственная школа, Черноморский парк 26 га,
                1,5 км до моря и полноценная городская инфраструктура.
              </p>
              <p class="hero745__offer-line">Черноморский парк 26 га · школа-гимназия «Эврика» · 1,5 км до моря</p>
              <div class="hero745__actions hero745__actions--stacked">
                <a class="button745 button745--primary" href="#contact">запросить консультацию</a>
              </div>
            </div>

            <aside class="hero745__card hero745__card--floating">
              <div class="hero745__card-body">
                <h2>«Горгиппия» — жилой сценарий для тех, кто хочет жить у моря постоянно, а не только приезжать на лето</h2>
                <p class="hero745__meta">Черноморский парк 26 га · школа-гимназия «Эврика» · 1,5 км до моря</p>
                <p>
                  Этот проект можно показывать не как ещё один курортный ЖК, а как самодостаточный микрорайон,
                  где семья живёт полноценно: со школой, парком, инфраструктурой и Черноморским берегом в шаговой доступности.
                </p>
              </div>
            </aside>
          </div>
        </div>
      </section>

      <section class="section section--tight triggers745-wrap triggers745-wrap--hero-continued">
        <div class="hero745__backdrop hero745__backdrop--continued" style={`--section-bg: url(${images.hero})`}></div>
        <div class="triggers745__tone"></div>
        <div class="container triggers745__container">
          <div class="section745-heading center745 section745-heading--light section745-heading--max triggers745__heading">
            <h2>Иногда проблема не в том, что нет квартиры у моря. А в том, что большинство предложений — это либо море без инфраструктуры, либо инфраструктура без моря.</h2>
          </div>
          <div class="triggers745">
            {triggerPoints.map((item) => <p>{item}</p>)}
          </div>
        </div>
      </section>

      <section class="immersive745 immersive745--hero" style={`--immersive-bg: url(${images.aha1})`}>
        <div class="container immersive745__inner">
          <div class="immersive745__card">
              <p class="immersive745__eyebrow">МКР «Горгиппия» · жизнь у Черноморского берега</p>
              <h2>«Горгиппию» можно подать не как «ещё один курортный ЖК», а как единственный в Анапе микрорайон, где семья живёт полноценно у моря</h2>
              <p class="immersive745__body immersive745__body--light">
                Если посмотреть на «Горгиппию» не через общий рынок курортной недвижимости, а через задачу семьи,
                которая хочет жить у моря постоянно, в ней можно увидеть не просто квартиру у берега, а самодостаточную среду.
              </p>
              <p class="immersive745__body immersive745__body--light">
                Здесь ценность создают не абстрактные преимущества, а конкретные условия: собственная школа-гимназия «Эврика»,
                Черноморский парк 26 га, 1,5 км до моря, заповедные зоны Сукко и Утриш в 15 минутах.
              </p>
              <p class="immersive745__body immersive745__body--light">
                Поэтому «Горгиппия» может читаться как выбор не ради переезда к морю самого по себе, а ради более качественной,
                устойчивой и полноценной жизни семьи на годы вперёд.
              </p>
              <div class="immersive745__facts">
                <span>Черноморский парк 26 га — природа как часть ежедневного уклада, а не разовые выезды</span>
                <span>Школа-гимназия «Эврика» и детсады прямо в микрорайоне — дети учатся там, где живут</span>
                <span>1,5 км до моря и 15 минут до заповедных зон Сукко и Утриш</span>
                <span>Система «всё включено» — единственный такой проект в Анапе</span>
              </div>
              <p class="immersive745__bridge immersive745__bridge--light">Это и есть главный поворот: семья покупает не квартиру у моря, а полноценную жизнь у Черноморского берега.</p>
          </div>
        </div>
      </section>

      <section class="section responses745 section--photo-soft" style={`--section-bg: url(${images.aha2})`}>
        <div class="responses745__veil"></div>
        <div class="container responses745__container">
          <div class="section745-heading center745 section745-heading--light">
            <h2>Три причины, почему семья, мечтающая о море, узнаёт себя в «Горгиппии»</h2>
          </div>
          <div class="responses745__stack">
            {responseCards.map((card) => (
              <article class="response745-card">
                <div class="response745-card__media">
                  <img src={card.image} alt={card.alt} loading="lazy" />
                </div>
                <div class="response745-card__body">
                  <div class="response745-card__number">{card.number}</div>
                  <h3>{card.title}</h3>
                  <p class="response745-card__problem">{card.problem}</p>
                  <p>{card.answer}</p>
                  <p class="response745-card__detail">{card.detail}</p>
                  {card.cta && (
                    <a class="inline-link745" href="#contact">{card.cta}</a>
                  )}
                </div>
              </article>
            ))}
          </div>
        </div>
      </section>

      <section class="split-photo745">
        <div class="split-photo745__image" style={`--split-bg: url(${images.qualifier})`}></div>
        <div class="split-photo745__content-wrap">
          <div class="container split-photo745__container">
            <div class="split-photo745__content">
              <p class="immersive745__eyebrow">МКР «Горгиппия» · самоотбор аудитории</p>
              <h2>Этот сценарий узнают не все — а те, кто хочет жить у моря постоянно, а не только приезжать</h2>
              <div class="self745 self745--transparent self745--light">
                {selfSelection.map((item) => <p>{item}</p>)}
              </div>
              <blockquote class="quote745 quote745--light">
                <p>
                  «Не «квартира у моря», а самодостаточный микрорайон с инфраструктурой, парком и 1,5 км до Черноморского берега».
                </p>
                <footer>Сегмент постоянной жизни у моря</footer>
              </blockquote>
            </div>
          </div>
        </div>
      </section>

      <section class="immersive745 immersive745--contrast" style={`--immersive-bg: url(${images.aha3})`}>
        <div class="container immersive745__inner immersive745__inner--right">
          <div class="immersive745__card immersive745__card--single-story">
              <div class="story745-card story745-card--light-copy">
              <div class="story745-card__number">05</div>
              <h2>Переезд к морю должен не просто изменить адрес, а дать семье полноценную жизнь — с инфраструктурой, природой и уверенностью в завтрашнем дне.</h2>
              <p class="story745-card__problem">Именно здесь ВКБ-Новостройки может перейти от общей категории «курортной недвижимости» к более точному позиционированию: единственный в Анапе микрорайон по системе «всё включено».</p>
              <a class="inline-link745 inline-link745--light" href="#contact">Посмотреть, как эта логика собирается в сегментный оффер и новую подачу</a>
            </div>
          </div>
        </div>
      </section>



      <section class="section compare745 section--contrast">
        <div class="compare745__backdrop" style={`--compare-bg: url(${images.compare})`}></div>
        <div class="container compare745__container">
          <div class="section745-heading section745-heading--light section745-heading--max">
            <p class="section745-heading__eyebrow">Как этот сегмент превращается в управленческое решение</p>
            <h2>Как общий язык про «курортную недвижимость» можно превратить в точное попадание в сегмент постоянной жизни у моря</h2>
          </div>
          <div class="compare745__grid">
            {comparisons.map((item) => (
              <article class="compare745-card">
                <p class="compare745-card__eyebrow">{item.overline}</p>
                <h3>{item.title}</h3>
                <p>{item.text}</p>
              </article>
            ))}
          </div>
        </div>
      </section>

      <section class="section process745 section--photo-band" style={`--section-bg: url(${images.footer})`}>
        <div class="section-band745__overlay section-band745__overlay--dark"></div>
        <div class="container process745__container">
          <div class="section745-heading center745 section745-heading--light section745-heading--max">
            <h2>Как превратить общий язык про «квартиру у моря» в точное попадание в сегмент постоянной черноморской жизни</h2>
