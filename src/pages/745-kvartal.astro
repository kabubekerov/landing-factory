---
import Analytics from '../components/Analytics.astro';
import '../styles/global.css';

const slug = '745-kvartal';
const formName = `landing-${slug}`;

const images = {
  hero: '/assets/745-kvartal/original/hero_hero.webp',
  aha1: '/assets/745-kvartal/original/aha1_silence.webp',
  aha2: '/assets/745-kvartal/original/aha2_community.webp',
  aha3: '/assets/745-kvartal/original/aha3_soul.webp',
  qualifier: '/assets/745-kvartal/original/qualifier_who.webp',
  compare: '/assets/745-kvartal/original/advantages_compare.webp',
  evolution: '/assets/745-kvartal/original/evolution_levels.webp',
  footer: '/assets/745-kvartal/original/footer_cta.webp',
};

const triggerPoints = [
  'Вы устали от архитектуры, которая кричит, навязывает статус и лишает воздуха.',
  'Вы ищете дом, где не нужно ничего доказывать соседям, потому что вы уже всё доказали себе.',
  'Вы хотите жить в центре города, но при этом сохранить тишину, приватность и свой внутренний ритм.',
];

const responseCards = [
  {
    number: '01',
    title: 'Право на тишину',
    problem: '«Современные ЖК слишком шумные и плотные. В них нет места, чтобы просто побыть в тишине после работы».',
    answer:
      'Я закрываю дверь, и город остается снаружи. Здесь архитектура не давит на меня. Я могу читать в тишине и ужинать, глядя на парк, а не в окна соседям.',
    cta: 'Хотите увидеть планировки вживую? → Запросить показ',
    image: images.aha1,
    alt: 'Светлый интерьер квартиры с высоким потолком и видом на тихую улицу',
  },
  {
    number: '02',
    title: 'Культура «своих»',
    problem: '«Я боюсь оказаться в доме, где соседи соревнуются в статусе, а не уважают личные границы».',
    answer:
      'Здесь нет ярмарки тщеславия. В лифте я встречаю людей, с которыми мы говорим на одном языке — не громко, но в точку. Это комьюнити нормальных, достойных людей.',
    image: images.aha2,
    alt: 'Тёплый интерьер лобби, где общаются двое жителей дома',
  },
  {
    number: '03',
    title: 'Жизнь без компромиссов',
    problem:
      '«Чтобы жить в правильной атмосфере, мне приходится мириться со старыми трубами и отсутствием паркинга в историческом центре».',
    answer:
      'Мне больше не нужно выбирать между духом старой Перми и современным комфортом. Я получил дом, в который можно вписаться, не теряя себя.',
    cta: 'Готовы поговорить? → Написать нам',
    image: images.aha3,
    alt: 'Контраст старого города и сдержанного современного интерьера',
  },
];

const selfSelection = [
  'Когда вы понимаете, что статус — это то, что внутри, а не то, что нужно выставлять напоказ.',
  'Когда вы переросли суету и ищете пространство, соразмерное вашему внутреннему масштабу.',
  'Когда для вас «нормально» и «по-человечески» — это высшая форма похвалы.',
];

const comparisons = [
  {
    overline: 'Против «элитных» ЖК',
    title: 'Благородная сдержанность',
    text: 'Мы не продаем золотые вензеля и искусственный пафос. Мы предлагаем благородную сдержанность.',
  },
  {
    overline: 'Против старого фонда',
    title: 'Историческая атмосфера — без исторических проблем',
    text: 'Дух старой Перми без изношенных коммуникаций, без случайных соседей, без отсутствия паркинга.',
  },
  {
    overline: 'Против массовой застройки',
    title: 'Приватность как архитектурный принцип',
    text: 'Малое количество соседей на этаже. Уважение к вашему личному пространству заложено в проект.',
  },
];

const lifeStages = [
  {
    stage: 'Первый свой',
    price: 'От 8,5 млн ₽',
    who: 'Вы впервые покупаете жильё полностью «под себя», без компромиссов с родственниками или партнёрами.',
    hire: 'Пространство, где вы наконец можете быть собой — без чужих правил и чужого вкуса.',
    format: 'Студии и 1-комнатные с авторской планировкой. Вход в культуру 745.',
  },
  {
    stage: 'Тихий центр',
    price: 'От 14,2 млн ₽',
    who: 'Вы живёте в историческом центре, но устали от изношенных коммуникаций и случайных соседей.',
    hire: 'Атмосферу старой Перми — но с современным комфортом и правильным окружением.',
    format: '2-комнатные с видовыми характеристиками. Переезд без потери духа.',
  },
  {
    stage: 'Пространство для жизни',
    price: 'От 21,5 млн ₽',
    who: 'Вы всё доказали. Вам нужен дом, который соответствует тому, кем вы стали — без лишних слов.',
    hire: 'Среду, где культура — это не декор, а способ жить. Где соседи — «свои».',
    format: '3-комнатные и семейные форматы. Пространство для тех, кто уже дома.',
  },
  {
    stage: 'Личная территория',
    price: 'От 35,0 млн ₽',
    who: 'Вы цените абсолютную приватность и хотите, чтобы ваш дом был вашей крепостью — видовой, закрытой, неповторимой.',
    hire: 'Собственное пространство над городом, где никто не смотрит в ваши окна.',
    format: 'Видовые квартиры верхних этажей с террасами. Только для «своих».',
  },
];

const processSteps = [
  {
    number: '01',
    title: 'Вы оставляете запрос',
    text: 'Сообщаете, что для вас важно: тишина, планировка, приватность, вид, семейный формат или инвестиционная логика.',
  },
  {
    number: '02',
    title: 'Мы собираем персональный сценарий',
    text: 'Не отправляем обезличенную подборку, а подбираем релевантные варианты именно под ваш ритм жизни и запрос.',
  },
  {
    number: '03',
    title: 'Приглашаем на спокойную встречу',
    text: 'Показываем материалы, планировки и сценарии покупки без навязчивости и давления.',
  },
  {
    number: '04',
    title: 'Вы выбираете своё',
    text: 'В фокусе не метраж как таковой, а квартира, в которой действительно можно жить по себе.',
  },
];
---

<html lang="ru">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>ЖК «745 квартал» — Жить по себе</title>
    <meta
      name="description"
      content="47 квартир бизнес-класса в тихом центре Перми для тех, кто живёт по себе. Закрытая встреча, планировки и материалы — по приглашению."
    />
  </head>
  <body class="landing-745">
    <Analytics landingSlug={slug} />

    <main>
      <section class="hero745 section section--photo-hero">
        <div class="hero745__backdrop" style={`--section-bg: url(${images.hero})`}></div>
        <div class="container hero745__container">
          <div class="hero745__label">ЖК «745 квартал» · Пермь · Тихий центр</div>
          <div class="hero745__grid">
            <div class="hero745__content hero745__content--glass">
              <h1>Кто сказал, что быть собой — <em>для пермяка недостаточно?</em></h1>
              <p class="hero745__lead">
                Мы верим, что город должен слышать своих. Что быть старым пермяком — это честь.
                ЖК «745 квартал» — это среда для тех, кто не нуждается в доказательствах. Жить
                по себе. Не выше. Не громче. А с достоинством.
              </p>
              <div class="hero745__actions">
                <a class="button745 button745--primary" href="#contact">Получить персональное предложение</a>
              </div>
            </div>

            <aside class="hero745__card hero745__card--floating">
              <div class="hero745__card-body">
                <h2>47 квартир бизнес-класса в тихом центре Перми для тех, кто выбирает не статус, а совпадение с собой</h2>
                <p class="hero745__meta">Сдача — IV квартал 2025 · Закрытая презентация — по приглашению</p>
                <p>
                  Малый дом. Конкретные люди. Правильная интонация. Мы создаём не просто жилой комплекс,
                  а редкую среду, где архитектура не спорит с человеком, а поддерживает его характер.
                </p>
              </div>
            </aside>
          </div>
        </div>
      </section>

      <section class="section section--tight triggers745-wrap section--photo-band" style={`--section-bg: url(${images.aha3})`}>
        <div class="section-band745__overlay"></div>
        <div class="container triggers745__container">
          <div class="triggers745">
            {triggerPoints.map((item) => <p>{item}</p>)}
          </div>
        </div>
      </section>

      <section class="immersive745 immersive745--hero" style={`--immersive-bg: url(${images.aha1})`}>
        <div class="container immersive745__inner">
          <div class="immersive745__card">
            <p class="immersive745__eyebrow">745 квартал · Право на тишину</p>
            <h2>Когда дом не вторгается в вашу жизнь, а бережно собирает её вокруг вас</h2>
            <p>
              В исходном ощущении этого проекта важна не только рациональность. Важна редкая роскошь —
              возможность выдохнуть, остаться наедине с собой и не чувствовать постоянное давление города.
            </p>
          </div>
        </div>
      </section>

      <section class="section responses745 section--photo-soft" style={`--section-bg: url(${images.aha2})`}>
        <div class="responses745__veil"></div>
        <div class="container responses745__container">
          <div class="section745-heading center745 section745-heading--light">
            <h2>Как 745 квартал отвечает на то, что вас останавливало</h2>
          </div>
          <div class="responses745__stack">
            {responseCards.map((card) => (
              <article class="response745-card">
                <div class="response745-card__media">
                  <img src={card.image} alt={card.alt} loading="lazy" />
                </div>
                <div class="response745-card__body">
                  <div class="response745-card__number">{card.number}</div>
                  <h3>{card.title}</h3>
                  <p class="response745-card__problem">{card.problem}</p>
                  <p>{card.answer}</p>
                  {card.cta && (
                    <a class="inline-link745" href="#contact">{card.cta}</a>
                  )}
                </div>
              </article>
            ))}
          </div>
        </div>
      </section>

      <section class="split-photo745">
        <div class="split-photo745__image" style={`--split-bg: url(${images.qualifier})`}></div>
        <div class="split-photo745__content-wrap">
          <div class="container split-photo745__container">
            <div class="split-photo745__content">
              <p class="immersive745__eyebrow">745 квартал · Узнайте себя</p>
              <h2>Дом имеет смысл только тогда, когда совпадает с вашим внутренним масштабом</h2>
              <div class="self745 self745--transparent">
                {selfSelection.map((item) => <p>{item}</p>)}
              </div>
              <blockquote class="quote745 quote745--light">
                <p>
                  «В Перми есть особая интонация. Умение молчать и слушать. 745 квартал — это первое
                  место за долгое время, которое построено именно с этой интонацией. Без нажима».
                </p>
                <footer>Амбассадор проекта · Архитектор, Пермь</footer>
              </blockquote>
            </div>
          </div>
        </div>
      </section>

      <section class="immersive745 immersive745--contrast" style={`--immersive-bg: url(${images.compare})`}>
        <div class="container immersive745__inner immersive745__inner--right">
          <div class="immersive745__card immersive745__card--wide">
            <p class="immersive745__eyebrow">745 квартал · Мы не для всех</p>
            <h2>Мы не продаём золотые вензеля, старый фонд или массовый компромисс. Мы собираем редкую среду.</h2>
            <div class="comparisons745__grid">
              {comparisons.map((item) => (
                <article class="comparison745-card comparison745-card--overlay">
                  <p class="comparison745-card__overline">{item.overline}</p>
                  <h3>{item.title}</h3>
                  <p>{item.text}</p>
                </article>
              ))}
            </div>
          </div>
        </div>
      </section>

      <section class="section life745 section--photo-soft" style={`--section-bg: url(${images.evolution})`}>
        <div class="responses745__veil responses745__veil--warm"></div>
        <div class="container life745__container">
          <div class="section745-heading center745 section745-heading--light section745-heading--max">
            <h2>На каком этапе вашей жизни вы хотите жить?</h2>
            <p>Мы не продаём квадратные метры. Мы предлагаем выбрать, на каком этапе вашей жизни вы хотите жить.</p>
          </div>
          <div class="life745-table-wrap">
            <table class="life745-table">
              <thead>
                <tr>
                  <th>Этап</th>
                  <th>Кто вы сейчас</th>
                  <th>Что вы нанимаете</th>
                  <th>Формат в 745 квартале</th>
                </tr>
              </thead>
              <tbody>
                {lifeStages.map((item) => (
                  <tr>
                    <td>
                      <strong>{item.stage}</strong>
                      <span>{item.price}</span>
                    </td>
                    <td>{item.who}</td>
                    <td>{item.hire}</td>
                    <td>{item.format}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
          <div class="center745 action745-wrap">
            <a class="button745 button745--ghost" href="#contact">Подобрать квартиру под свой сценарий жизни</a>
          </div>
        </div>
      </section>

      <section class="section process745 section--photo-band" style={`--section-bg: url(${images.footer})`}>
        <div class="section-band745__overlay section-band745__overlay--dark"></div>
        <div class="container process745__container">
          <div class="section745-heading center745 section745-heading--light section745-heading--max">
            <h2>Как проходит путь к персональному предложению</h2>
          </div>
          <div class="process745__grid">
            {processSteps.map((step) => (
              <article class="process745-card process745-card--light">
                <div class="process745-card__number">{step.number}</div>
                <div>
                  <h3>{step.title}</h3>
                  <p>{step.text}</p>
                </div>
              </article>
            ))}
          </div>
        </div>
      </section>

      <section id="contact" class="section final745 final745--photo">
        <div class="final745__backdrop" style={`--final-bg: url(${images.footer})`}></div>
        <div class="container final745__container">
          <div class="final745__layout">
            <div class="final745__media-copy">
              <p class="final745__eyebrow">745 квартал · Персональное предложение по приглашению</p>
              <h2>Узнайте, как жить по себе — и получите персональное предложение именно под ваш ритм жизни</h2>
              <p class="final745__lead final745__lead--light">
                Мы подберём релевантные планировки, ценовой сценарий и формат встречи так, чтобы разговор начинался не с давления,
                а с понимания того, что для вас действительно важно.
              </p>
            </div>
            <div class="final745__card">
              <p class="final745__eyebrow">Закрытый диалог без навязчивых продаж</p>
              <h3 class="final745__form-title">Оставьте контакты — и мы соберём для вас персональное предложение по 745 кварталу</h3>
              <p class="final745__lead">
                С учётом вашего запроса, этапа жизни и того, каким должен быть дом, где действительно можно быть собой.
              </p>
              <form
                name={formName}
                method="POST"
                data-netlify="true"
                netlify-honeypot="bot-field"
                action="/thank-you"
                class="final745__form"
              >
                <input type="hidden" name="form-name" value={formName} />
                <input type="hidden" name="landing_slug" value={slug} />
                <input type="hidden" name="utm_source" value="" />
                <input type="hidden" name="utm_medium" value="" />
                <input type="hidden" name="utm_campaign" value="" />
                <input type="hidden" name="utm_content" value="" />
                <input type="hidden" name="utm_term" value="" />

                <p class="sr-only">
                  <label>
                    Не заполняйте это поле, если вы человек:
                    <input name="bot-field" />
                  </label>
                </p>

                <div class="final745__form-grid">
                  <div>
                    <label for="name" class="field-label745">Как к вам обращаться</label>
                    <input type="text" id="name" name="name" required class="field-input745" />
                  </div>

                  <div>
                    <label for="phone" class="field-label745">Телефон или мессенджер</label>
                    <input type="tel" id="phone" name="phone" required class="field-input745" />
                  </div>

                  <div>
                    <label for="email" class="field-label745">Email</label>
                    <input type="email" id="email" name="email" class="field-input745" />
                  </div>

                  <div class="final745__form-full">
                    <label for="message" class="field-label745">Что особенно важно для вас</label>
                    <textarea
                      id="message"
                      name="message"
                      rows="5"
                      class="field-input745 field-textarea745"
                      placeholder="Например: тишина, 2-комнатная планировка, приватность, семейный формат, диапазон бюджета, формат личной встречи"
                    ></textarea>
                  </div>
                </div>

                <button type="submit" class="button745 button745--primary final745__submit">
                  Узнать, как жить по себе, и получить персональное предложение
                </button>
              </form>
            </div>
          </div>
        </div>
      </section>
    </main>

    <script define:vars={{ slug }}>
      import { populateUTMFields, trackFormSubmission } from '../utils/analytics.ts';

      const form = document.querySelector('#contact form');

      if (form instanceof HTMLFormElement) {
        populateUTMFields(form);
        form.addEventListener('submit', () => {
          populateUTMFields(form);
          trackFormSubmission(slug);
        });
      }
    </script>
  </body>
</html>

<style>
  :global(body.landing-745) {
    background: #130f0d;
    color: #241b16;
  }

  .landing-745 main {
    overflow-x: hidden;
    background: #f6efe8;
  }

  .section {
    position: relative;
  }

  .hero745,
  .life745,
  .final745,
  .responses745,
  .process745 {
    position: relative;
  }

  .hero745__container,
  .responses745__container,
  .life745__container,
  .process745__container,
  .final745__container {
    position: relative;
    z-index: 2;
  }

  .section--photo-hero,
  .section--photo-band,
  .section--photo-soft,
  .final745--photo {
    background-image: var(--section-bg);
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
  }

  .hero745 {
    min-height: 100vh;
    display: flex;
    align-items: stretch;
    padding: 48px 0;
    overflow: hidden;
  }

  .hero745__backdrop {
    position: absolute;
    inset: 0;
    background-image: var(--section-bg);
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
  }

  .hero745__backdrop::after,
  .section-band745__overlay,
  .responses745__veil,
  .immersive745::before,
  .split-photo745__image::after,
  .split-photo745__content-wrap::before,
  .final745__backdrop::after {
    content: '';
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  .hero745__backdrop::after {
    background:
      linear-gradient(90deg, rgba(16, 12, 10, 0.62) 0%, rgba(16, 12, 10, 0.34) 38%, rgba(16, 12, 10, 0.56) 100%),
      linear-gradient(180deg, rgba(16, 12, 10, 0.14) 0%, rgba(16, 12, 10, 0.42) 100%);
  }

  .hero745__label,
  .final745__eyebrow,
  .comparison745-card__overline,
  .immersive745__eyebrow {
    display: inline-flex;
    align-items: center;
    padding: 10px 14px;
    border-radius: 999px;
    background: rgba(255, 247, 240, 0.14);
    color: #fff0e4;
    font-size: 14px;
    font-weight: 700;
    letter-spacing: 0.02em;
    text-transform: uppercase;
    backdrop-filter: blur(8px);
    border: 1px solid rgba(255, 247, 240, 0.16);
  }

  .hero745__grid,
  .final745__layout {
    display: grid;
    grid-template-columns: minmax(0, 1.1fr) minmax(320px, 0.72fr);
    gap: 28px;
    align-items: end;
    position: relative;
    z-index: 1;
    min-height: calc(100vh - 96px);
