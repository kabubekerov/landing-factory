---
import Analytics from '../components/Analytics.astro';
import '../styles/global.css';

const slug = 'stay-but-grow';
const formName = `landing-${slug}`;

const images = {
  hero: '/assets/stay-but-grow/original/hero_hero.jpg',
  aha1: '/assets/stay-but-grow/original/aha1_lobby.jpg',
  aha2: '/assets/stay-but-grow/original/aha2_view.jpg',
  aha3: '/assets/stay-but-grow/original/aha3_space.jpg',
  qualifier: '/assets/stay-but-grow/original/qualifier_who.jpg',
  evolution: '/assets/stay-but-grow/original/aha2_view.jpg',
  footer: '/assets/stay-but-grow/original/footer_cta.jpg',
  currentPositioning: '/assets/stay-but-grow/original/current_positioning.jpg',
};

const triggerPoints = [
  'Вы давно живёте в этом городе и не хотите его менять — но чувствуете, что выросли из текущего жилья.',
  'Вы не ищете новый старт и не переезжаете ради перемен. Вы просто хотите, чтобы дом наконец совпал с тем, кем вы стали.',
  'Вам важно остаться в своём городе, в своём ритме — но жить в среде, которая соответствует вашему реальному уровню жизни.',
];

const responseCards = [
  {
    number: '01',
    title: 'Остаться в своём городе — и наконец выдохнуть',
    problem: '«Я не хочу никуда переезжать. Я люблю этот город, здесь мои связи, мой бизнес, мой ритм. Но текущее жильё перестало соответствовать тому, кем я стал».',
    answer:
      'Переезд не обязательно означает смену города. Иногда это просто переход в среду, которая наконец совпадает с тем, как вы живёте сейчас. Тот же город, та же жизнь — но дом, в котором больше не нужно ничего терпеть.',
    detail:
      'Не эмиграция, не побег, не новый старт. Просто апгрейд среды внутри привычного города — без потери всего, что здесь важно.',
    cta: 'Посмотреть, как этот сценарий упаковать для вашего проекта',
    image: images.aha1,
    alt: 'Статусное лобби с приглушённым светом — первое ощущение нового уровня',
  },
  {
    number: '02',
    title: 'Среда, которая соответствует реальному уровню жизни',
    problem: '«Я вырос из текущего жилья. Но переезжать в другой город не хочу — здесь всё моё. Просто хочу жить в среде, которая соответствует тому, кем я стал».',
    answer:
      'Есть момент, когда человек понимает: дом больше не совпадает с его реальным образом жизни. Не потому что плохой — а потому что он сам стал другим. Это не кризис, это рост. И решение здесь — не переезд в другой город, а переход в другую среду внутри своего.',
    detail:
      'Вид из окна, лобби, паркинг, соседи — всё это формирует ощущение своего уровня. Когда среда совпадает с человеком, он перестаёт тратить энергию на внутреннее несоответствие.',
    cta: 'Обсудить, как показать этот переход в позиционировании проекта',
    image: images.aha2,
    alt: 'Панорамный вид из окна нового ЖК — знакомый город, новый уровень',
  },
  {
    number: '03',
    title: 'Апгрейд без потери себя',
    problem: '«Я не хочу ничего менять в своей жизни. Я просто хочу, чтобы дом наконец совпал с тем, кем я стал. Без переезда в другой город, без потери связей, без нового старта с нуля».',
    answer:
      'Это не про то, чтобы стать кем-то другим. Это про то, чтобы жить в среде, которая честно отражает, кем вы уже являетесь. Тот же город, те же люди, тот же ритм — но пространство, которое наконец перестало тебя сдерживать.',
    detail:
      'Апгрейд среды без потери идентичности. Переход на новый уровень без смены всего, что важно. Это и есть суть сценария «остаться, но вырасти».',
    cta: 'Если у вашего проекта есть ценность для этого сегмента — давайте это разберём',
    image: images.aha3,
    alt: 'Просторная квартира с большими окнами — пространство, которое не сдерживает',
  },
];

const selfSelection = [
  'Когда вы понимаете, что выросли из текущего жилья — но не хотите менять город и привычный ритм жизни.',
  'Когда вам важно остаться в своём городе, сохранить связи и бизнес, но жить в среде, которая наконец совпадает с вашим реальным уровнем.',
  'Когда «переехать» для вас означает не новый старт, а просто апгрейд среды внутри привычного города.',
];

const lifeStages = [
  {
    stage: 'Первое жильё',
    price: 'Стартовый этап',
    who: 'Вы только начинаете самостоятельную жизнь. Главное — своё пространство, пусть и небольшое.',
    hire: 'Независимость и собственный старт. Жильё как точка опоры.',
    format: 'Студии и 1-комнатные. Важна цена входа и локация.',
  },
  {
    stage: 'Жильё под задачу',
    price: 'Функциональный этап',
    who: 'Жизнь усложнилась: семья, работа, ритм. Нужно пространство, которое поддерживает, а не мешает.',
    hire: 'Практичность и соответствие текущему укладу. Дом как инструмент.',
    format: '2-3 комнатные. Район, планировка, инфраструктура.',
  },
  {
    stage: 'Апгрейд среды',
    price: 'Сегмент «Остаться, но вырасти»',
    who: 'Вы выросли из текущего жилья, но не хотите менять город. Нужна среда, которая совпадает с тем, кем вы стали.',
    hire: 'Соответствие среды реальному уровню жизни. Апгрейд без потери идентичности.',
    format: 'Бизнес-класс в своём городе. Тот же ритм — другая среда.',
  },
  {
    stage: 'Среда как статус',
    price: 'Премиум-этап',
    who: 'Дом — это не просто жильё, а отражение достигнутого. Важно всё: адрес, соседи, детали.',
    hire: 'Подтверждение уровня и принадлежности. Среда как часть идентичности.',
    format: 'Премиум и элит. Адрес, вид, эксклюзивность.',
  },
];

const processSteps = [
  {
    number: '01',
    title: 'Вы оставляете контакты и ссылку на проект',
    text: 'Показываете текущий ЖК, лендинг или рекламную коммуникацию, которая не даёт нужной конверсии.',
  },
  {
    number: '02',
    title: 'Мы собираем гипотезу переупаковки',
    text: 'Смотрим, подходит ли проект под сценарий «остаться, но вырасти», и находим, где именно теряется ценность в текущей подаче.',
  },
  {
    number: '03',
    title: 'Проводим встречу по проекту',
    text: 'Показываем, как может выглядеть более точное позиционирование под сценарий апгрейда среды без смены города.',
  },
  {
    number: '04',
    title: 'Фиксируем следующий шаг',
    text: 'Определяем, что именно нужно делать дальше: корректировать сегмент, перепрошивать оффер или полностью пересобирать упаковку проекта.',
  },
];
---

<html lang="ru">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>Остаться, но вырасти — апгрейд среды без смены города</title>
    <meta
      name="description"
      content="Позиционирование жилого проекта под сегмент «Остаться, но вырасти». Для тех, кто вырос из текущего жилья, но не хочет менять город — только среду."
    />
  </head>
  <body class="landing-745">
    <Analytics landingSlug={slug} />

    <main>
      <section class="hero745 section section--photo-hero">
        <div class="hero745__backdrop" style={`--section-bg: url(${images.hero})`}></div>
        <div class="container hero745__container">
          <div class="hero745__label">Сегментная упаковка · Остаться, но вырасти · Апгрейд среды</div>
          <div class="hero745__grid">
            <div class="hero745__content hero745__content--glass">
              <h1>Вы выросли из текущего жилья. <em>Но не из своего города.</em></h1>
              <p class="hero745__lead">
                Есть момент, когда человек понимает: дом больше не совпадает с его реальным образом жизни.
                Не потому что плохой — а потому что он сам стал другим. Решение здесь — не переезд в другой город,
                а переход в другую среду внутри своего.
              </p>
              <p class="hero745__offer-line">Тот же город. Тот же ритм. Другая среда.</p>
              <div class="hero745__actions hero745__actions--stacked">
                <a class="button745 button745--primary" href="#contact">Посмотреть предложение</a>
              </div>
            </div>

            <aside class="hero745__card hero745__card--floating">
              <div class="hero745__card-body">
                <h2>Для тех, кто хочет остаться в своём городе — но жить в среде, которая наконец совпадает с тем, кем они стали</h2>
                <p class="hero745__meta">Сегмент «Остаться, но вырасти» · Апгрейд среды · Без смены города</p>
                <p>
                  Не эмиграция, не побег, не новый старт. Просто апгрейд среды внутри привычного города —
                  без потери всего, что здесь важно. Те же связи, тот же бизнес, тот же ритм — но дом, который наконец совпадает.
                </p>
              </div>
            </aside>
          </div>
        </div>
      </section>

      <section class="section section--tight triggers745-wrap triggers745-wrap--hero-continued">
        <div class="hero745__backdrop hero745__backdrop--continued" style={`--section-bg: url(${images.hero})`}></div>
        <div class="triggers745__tone"></div>
        <div class="container triggers745__container">
          <div class="triggers745">
            {triggerPoints.map((item) => <p>{item}</p>)}
          </div>
        </div>
      </section>

      <section class="immersive745 immersive745--hero" style={`--immersive-bg: url(${images.aha1})`}>
        <div class="container immersive745__inner">
          <div class="immersive745__card">
            <p class="immersive745__eyebrow">Сегмент «Остаться, но вырасти» · Апгрейд без потери себя</p>
            <h2>Когда продукт перестаёт продаваться как набор характеристик и начинает собираться вокруг подлинной задачи клиента</h2>
            <p>
              В этом сегменте важна не только цена и метраж. Важна точность попадания в напряжение: человек вырос,
              но не хочет терять привычный город и ритм жизни. Ему нужен апгрейд среды — без потери идентичности.
            </p>
            <div class="immersive745__facts">
              <span>Апгрейд среды</span>
              <span>Без смены города</span>
              <span>Сохранение идентичности</span>
              <span>Новый уровень жизни</span>
            </div>
          </div>
        </div>
      </section>

      <section class="section responses745 section--photo-soft" style={`--section-bg: url(${images.aha2})`}>
        <div class="responses745__veil"></div>
        <div class="container responses745__container">
          <div class="section745-heading center745 section745-heading--light">
            <h2>Как сегментная упаковка отвечает на то, что останавливает человека</h2>
          </div>
          <div class="responses745__stack">
            {responseCards.map((card) => (
              <article class="response745-card">
                <div class="response745-card__media">
                  <img src={card.image} alt={card.alt} loading="lazy" />
                </div>
                <div class="response745-card__body">
                  <div class="response745-card__number">{card.number}</div>
                  <h3>{card.title}</h3>
                  <p class="response745-card__problem">{card.problem}</p>
                  <p>{card.answer}</p>
                  <p class="response745-card__detail">{card.detail}</p>
                  {card.cta && (
                    <a class="inline-link745" href="#contact">{card.cta}</a>
                  )}
                </div>
              </article>
            ))}
          </div>
        </div>
      </section>

      <section class="split-photo745">
        <div class="split-photo745__image" style={`--split-bg: url(${images.qualifier})`}></div>
        <div class="split-photo745__content-wrap">
          <div class="container split-photo745__container">
            <div class="split-photo745__content">
              <p class="immersive745__eyebrow">Сегмент «Остаться, но вырасти» · Узнайте себя</p>
              <h2>Этот сценарий — для тех, кто вырос из текущего жилья, но не хочет менять город</h2>
              <div class="self745 self745--transparent">
                {selfSelection.map((item) => <p>{item}</p>)}
              </div>
              <blockquote class="quote745 quote745--light">
                <p>
                  «Иногда самое правильное решение — это не переезд в другой город, а переход в другую среду внутри своего.
                  Тот же город, те же люди, тот же ритм — но пространство, которое наконец перестало тебя сдерживать».
                </p>
                <footer>Из логики сегмента «Остаться, но вырасти»</footer>
              </blockquote>
              <a class="inline-link745 inline-link745--light" href="#contact">Если ваш проект подходит под этот сценарий — обсудим переупаковку</a>
            </div>
          </div>
        </div>
      </section>

      <section class="immersive745 immersive745--contrast" style={`--immersive-bg: url(${images.aha3})`}>
        <div class="container immersive745__inner immersive745__inner--right">
          <div class="immersive745__card immersive745__card--single-story">
            <div class="story745-card">
              <div class="story745-card__number">03</div>
              <h2>Апгрейд без потери себя</h2>
              <p class="story745-card__problem">«Я не хочу ничего менять в своей жизни. Я просто хочу, чтобы дом наконец совпал с тем, кем я стал. Без переезда в другой город, без потери связей, без нового старта с нуля».</p>
              <p>Это не про то, чтобы стать кем-то другим. Это про то, чтобы жить в среде, которая честно отражает, кем вы уже являетесь. Тот же город, те же люди, тот же ритм — но пространство, которое наконец перестало тебя сдерживать.</p>
              <a class="inline-link745" href="#contact">Если у вашего проекта есть ценность для этого сегмента — давайте это разберём</a>
            </div>
          </div>
        </div>
      </section>

      <section class="section life745 section--photo-soft" style={`--section-bg: url(${images.evolution})`}>
        <div class="responses745__veil responses745__veil--warm"></div>
        <div class="container life745__container">
          <div class="section745-heading center745 section745-heading--light section745-heading--max">
            <h2>На каком этапе своей эволюции клиент выбирает ваш продукт?</h2>
            <p>Эта таблица показывает не ассортимент, а логику того, как сегмент, жизненная ситуация и Core Job соединяются в осмысленное позиционирование.</p>
          </div>
          <div class="life745-table-wrap">
            <table class="life745-table">
              <thead>
                <tr>
                  <th>Этап</th>
                  <th>Кто вы сейчас</th>
                  <th>Что вы нанимаете</th>
                  <th>Формат проекта</th>
                </tr>
              </thead>
              <tbody>
                {lifeStages.map((item) => (
                  <tr>
                    <td>
                      <strong>{item.stage}</strong>
                      <span>{item.price}</span>
                    </td>
                    <td>{item.who}</td>
                    <td>{item.hire}</td>
                    <td>{item.format}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
          <div class="center745 action745-wrap">
            <a class="button745 button745--ghost" href="#contact">Обсудить, как упаковать ваш ЖК под сценарий «остаться, но вырасти»</a>
          </div>
        </div>
      </section>

      <section class="section process745 section--photo-band" style={`--section-bg: url(${images.footer})`}>
        <div class="section-band745__overlay section-band745__overlay--dark"></div>
        <div class="container process745__container">
          <div class="section745-heading center745 section745-heading--light section745-heading--max">
            <h2>Как проходит путь к переупаковке девелоперского продукта</h2>
          </div>
          <div class="process745__grid process745__grid--stacked">
            {processSteps.map((step) => (
              <article class="process745-card process745-card--light process745-card--stacked">
                <div class="process745-card__number">{step.number}</div>
                <h3>{step.title}</h3>
                <p>{step.text}</p>
              </article>
            ))}
          </div>
        </div>
      </section>

      <section id="contact" class="section final745 final745--photo">
        <div class="final745__backdrop" style={`--final-bg: url(${images.footer})`}></div>
        <div class="container final745__container">
          <div class="final745__layout">
            <div class="final745__media-copy">
              <p class="final745__eyebrow">Ваше текущее позиционирование vs. сегментная переупаковка</p>
              <h2>Если текущее позиционирование не приводит к продажам — оставьте контакты, и мы проведём встречу, где расскажем про наш подход</h2>
              <p class="final745__lead final745__lead--light">
                Покажем, как сейчас выглядит подача проекта — и как её можно переупаковать под сценарий «остаться, но вырасти» с точным попаданием в логику апгрейда среды без смены города.
              </p>
              <div class="final745__positioning-shot">
                <img src={images.currentPositioning} alt="Пример текущего позиционирования проекта девелопера" loading="lazy" />
              </div>
            </div>
            <div class="final745__card">
              <p class="final745__eyebrow">Стратегическая встреча по переупаковке</p>
              <h3 class="final745__form-title">Оставьте контакты — проведём встречу и расскажем про наш подход</h3>
              <p class="final745__lead">
                Разберём текущее позиционирование проекта, посмотрим, насколько он подходит для сегмента «остаться, но вырасти»,
                и покажем, как может выглядеть новая упаковка лендинга и оффера.
              </p>
              <form
                name={formName}
                method="POST"
                data-netlify="true"
                netlify-honeypot="bot-field"
                action="/thank-you"
                class="final745__form"
              >
                <input type="hidden" name="form-name" value={formName} />
                <input type="hidden" name="landing_slug" value={slug} />
                <input type="hidden" name="utm_source" value="" />
                <input type="hidden" name="utm_medium" value="" />
                <input type="hidden" name="utm_campaign" value="" />
                <input type="hidden" name="utm_content" value="" />
                <input type="hidden" name="utm_term" value="" />

                <p class="sr-only">
                  <label>
                    Не заполняйте это поле, если вы человек:
                    <input name="bot-field" />
                  </label>
                </p>

                <div class="final745__form-grid">
                  <div class="final745__field-block">
                    <label for="name" class="field-label745">Имя</label>
                    <input type="text" id="name" name="name" required class="field-input745" />
                  </div>

                  <div class="final745__field-block final745__form-full">
                    <label for="phone" class="field-label745">Телефон / Telegram</label>
                    <input type="tel" id="phone" name="phone" required class="field-input745" />
                  </div>

                  <div class="final745__field-block final745__form-full">
                    <label for="email" class="field-label745">Email</label>
                    <input type="email" id="email" name="email" required class="field-input745" />
                  </div>
                </div>

                <button type="submit" class="button745 button745--primary final745__submit">
                  Записаться на встречу
                </button>
                <p class="final745__submit-note">Если текущее позиционирование не приводит к продажам, оставьте контакты — проведём встречу.</p>
              </form>
            </div>
          </div>
        </div>
      </section>
    </main>

    <script define:vars={{ slug }}>
      import { populateUTMFields, trackFormSubmission } from '../utils/analytics.ts';

      const form = document.querySelector('#contact form');

      if (form instanceof HTMLFormElement) {
        populateUTMFields(form);
        form.addEventListener('submit', () => {
          populateUTMFields(form);
          trackFormSubmission(slug);
        });
      }
    </script>
  </body>
</html>

<style>
  :global(body.landing-745) {
    background: #130f0d;
    color: #241b16;
  }

  .landing-745 main {
    overflow-x: hidden;
    background: #f6efe8;
  }

  .section {
    position: relative;
  }

  .hero745,
