---
import Analytics from '../components/Analytics.astro';
import '../styles/global.css';

const slug = 'endemik-established';
const formName = `landing-${slug}`;

const images = {
  hero: '/assets/745-kvartal/original/hero_hero.webp',
  aha1: '/assets/745-kvartal/original/aha1_silence.webp',
  aha2: '/assets/745-kvartal/original/aha2_community.webp',
  aha3: '/assets/745-kvartal/original/aha3_soul.webp',
  qualifier: '/assets/745-kvartal/original/qualifier_who.webp',
  compare: '/assets/745-kvartal/original/advantages_compare.webp',
  evolution: '/assets/745-kvartal/original/evolution_levels.webp',
  footer: '/assets/745-kvartal/original/footer_cta.webp',
  currentPositioning: '/assets/745-kvartal/original/current_positioning.webp',
};

const triggerPoints = [
  'Вы давно можете позволить себе хорошее жильё, но большинство проектов в центре выглядят либо слишком шумно, либо слишком демонстративно.',
  'Вам нужен дом, где архитектура, приватность и адрес работают вместе — без ощущения, что вы покупаете статус напоказ.',
  'Выбирая квартиру, вы фактически выбираете способ жить: в тишине, в собранном ритме и без чужого сценария за стеной.',
];

const responseCards = [
  {
    number: '01',
    title: 'Не ещё один проект «для всех», а дом с правильной дистанцией',
    problem:
      'Частая проблема бизнес-класса в центре — достойная оболочка без ощущения внутренней тишины, приватности и взрослой собранности.',
    answer:
      'Эндемик можно подать как дом, где ценность возникает не из громкости, а из точного совпадения среды и человека: камерный масштаб, спокойная архитектура, ощущение защищённой личной территории.',
    detail:
      'Для сегмента «Одинокие и состоявшиеся» это не просто преимущество. Это главный критерий выбора среды, в которой хочется жить каждый день.',
    image: images.aha1,
    alt: 'Архитектурный образ тишины и приватности для ЖК Эндемик',
    cta: 'Обсудить такой угол подачи',
  },
  {
    number: '02',
    title: 'Центр — не как компромисс, а как удобная сцена для взрослой жизни',
    problem:
      'Люди этого сегмента не хотят уезжать из города, но и не готовы мириться с ощущением постоянного внешнего давления, случайного шума и проходного ритма.',
    answer:
      'Поэтому локация должна звучать не как география, а как контроль над повседневностью: всё рядом, но дом остаётся в своей интонации — без лишней суеты и ощущения общего потока.',
    detail:
      'Так проект начинает продавать не адрес, а качество ежедневного маршрута, в котором есть дистанция от хаоса и ощущение личного масштаба.',
    image: images.aha2,
    alt: 'Городская жизнь в своём ритме для аудитории Эндемика',
    cta: 'Посмотреть блок про городской ритм',
  },
  {
    number: '03',
    title: 'Дом как отражение зрелого вкуса, а не декларации статуса',
    problem:
      'Когда человек уже состоялся, ему не нужен крикливый премиум. Ему нужен дом, который совпадает с его представлением о себе — спокойно, точно и без лишних жестов.',
    answer:
      'В лендинге Эндемика архитектура, материалы, масштаб и ритм нужно собирать в ощущение редкого выбора — спокойного, уверенного и не требующего оправданий.',
    detail:
      'Именно этот тон переводит характеристики проекта в ясное желание оставить заявку и обсудить покупку предметно, а не просто пролистать ещё один красивый ЖК.',
    image: images.aha3,
    alt: 'Эстетика зрелого выбора и приватного статуса в ЖК Эндемик',
    cta: 'Перейти к финальному CTA',
  },
];

const selfSelection = [
  'Вы больше не хотите выбирать жильё по чужим критериям успеха — вам важнее совпадение с собственным ритмом, а не внешний шум вокруг проекта.',
  'Для вас тишина, приватность и архитектурная собранность важнее, чем громкие обещания и показной статус.',
  'Вы ищете дом, в котором комфорт ощущается не как набор опций, а как естественная среда для взрослой самостоятельной жизни.',
];

const comparisons = [
  {
    overline: 'Против общего бизнес-класса',
    title: 'Сдержанная архитектура вместо универсального глянца',
    text:
      'Мы не продаём проект через стандартный набор престижных атрибутов. Мы собираем образ дома, который выглядит спокойно, точно и взросло — и именно поэтому воспринимается дороже.',
  },
  {
    overline: 'Против «яркого премиума»',
    title: 'Приватность как ценность, а не как формальная характеристика',
    text:
      'Покупателю важна не только локация и статус, но и ощущение, что дом не вторгается в личную жизнь. Эндемик должен звучать как среда, где можно наконец выдохнуть.',
  },
  {
    overline: 'Против массовой застройки',
    title: 'Личный масштаб вместо ощущения общего потока',
    text:
      'Когда дом подаётся как редкий и собранный формат, он выигрывает не количеством обещаний, а ясностью своего характера и точностью попадания в нужный сегмент.',
  },
];

const lifeStages = [
  {
    stage: 'Редкий формат',
    price: 'Фокус коммуникации',
    who: 'Для самостоятельного взрослого человека, который выбирает не просто квартиру, а среду, совпадающую с его внутренним ритмом.',
    hire: 'Не демонстративный статус, а приватность, тишину, архитектурную собранность и ощущение личной территории.',
    format: 'Дом как точное совпадение со зрелым способом жить.',
  },
  {
    stage: 'Город без давления',
    price: 'Фокус локации',
    who: 'Для тех, кто хочет остаться в активном городском контексте, но не готов жить в атмосфере проходного двора и постоянного внешнего шума.',
    hire: 'Контроль над своим маршрутом, удобство центра и дистанцию от хаоса.',
    format: 'Локация как часть личного комфорта, а не как банальный плюс в списке.',
  },
  {
    stage: 'Зрелый вкус',
    price: 'Фокус эстетики',
    who: 'Для покупателей, которым уже не нужно ничего доказывать рынку, окружению или самим себе.',
    hire: 'Дом, который подтверждает вкус не криком, а правильной интонацией, материалом и ритмом.',
    format: 'Архитектура как отражение характера, а не как декоративная оболочка.',
  },
  {
    stage: 'Повод оставить заявку',
    price: 'Фокус CTA',
    who: 'Для человека, который должен узнать в проекте не «ещё один хороший ЖК», а именно своё будущее пространство жизни.',
    hire: 'Понять, насколько дом совпадает с его личным сценарием и ожиданием от среды.',
    format: 'Переход от красивого просмотра к предметному интересу и заявке.',
  },
];

const processSteps = [
  {
    number: '01',
    title: 'Собираем сегмент',
    description:
      'Фиксируем не демографию, а внутреннюю задачу аудитории: взрослый самостоятельный человек ищет не просто квартиру, а дом, в котором не нужно мириться с чужим ритмом.',
  },
  {
    number: '02',
    title: 'Переводим характеристики в сценарий жизни',
    description:
      'Локацию, архитектуру, масштаб дома и приватность собираем в цельное ценностное предложение, которое считывается как редкий формат, а не как ещё один список преимуществ.',
  },
  {
    number: '03',
    title: 'Строим финальный CTA для девелопера',
    description:
      'Форма и последний экран работают как приглашение к встрече по переупаковке лендинга: что именно менять в подаче, в блоках и в визуальной драматургии под сегмент.',
  },
];
---

<html lang="ru">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>ЖК «Эндемик» — лендинг в формате 745 для сегмента «Одинокие и состоявшиеся»</title>
    <meta
      name="description"
      content="Лендинг ЖК «Эндемик» в формате 745 для сегмента «Одинокие и состоявшиеся»: приватность, взрослый городской ритм, архитектурная собранность и встреча по переупаковке позиционирования."
    />
  </head>
  <body class="landing-745">
    <Analytics landingSlug={slug} />

    <main>
      <section class="hero745 section section--photo-hero">
        <div class="hero745__backdrop" style={`--section-bg: url(${images.hero})`}></div>
        <div class="container hero745__container">
          <div class="hero745__label">ЖК «Эндемик» · Для сегмента «Одинокие и состоявшиеся»</div>
          <div class="hero745__grid">
            <div class="hero745__content hero745__content--glass">
              <h1>Дом для тех, кто уже всё доказал — <em>и теперь выбирает жить в тишине, в своём масштабе, без чужих сценариев.</em></h1>
              <p class="hero745__lead">
                Эндемик — это приватный городской дом для аудитории, которая не ищет демонстративный статус,
                а выбирает совпадение дома со своим внутренним ритмом, приватностью и достоинством.
              </p>
              <p class="hero745__offer-line">Дом для самостоятельных и состоявшихся. Новая версия лендинга — в логике 745.</p>
              <div class="hero745__actions hero745__actions--stacked">
                <a class="button745 button745--primary" href="#contact">Ознакомиться с предложением</a>
              </div>
            </div>

            <aside class="hero745__card hero745__card--floating">
              <div class="hero745__card-body">
                <h2>Приватный формат для взрослой аудитории, которая выбирает не шум, а внутреннее совпадение с местом</h2>
                <p class="hero745__meta">Приватный формат · Собранная архитектура · Взрослый городской ритм</p>
                <p>
                  Малый дом. Сдержанная архитектура. Правильная интонация. Здесь среда не спорит с человеком,
                  а поддерживает тот образ жизни, в котором не нужно ничего демонстрировать.
                </p>
              </div>
            </aside>
          </div>
        </div>
      </section>

      <section class="section section--tight triggers745-wrap triggers745-wrap--hero-continued">
        <div class="hero745__backdrop hero745__backdrop--continued" style={`--section-bg: url(${images.hero})`}></div>
        <div class="triggers745__tone"></div>
        <div class="container triggers745__container">
          <div class="triggers745">
            {triggerPoints.map((item) => <p>{item}</p>)}
          </div>
        </div>
      </section>

      <section class="immersive745 immersive745--hero" style={`--immersive-bg: url(${images.aha1})`}>
        <div class="container immersive745__inner">
          <div class="immersive745__card">
            <p class="immersive745__eyebrow">ЖК «Эндемик» · Право на свой ритм</p>
            <h2>Когда проект перестаёт продаваться как набор характеристик и начинает собираться вокруг подлинной задачи клиента</h2>
            <p>
              В этом проекте важна не только эстетика. Важна точность попадания в напряжение аудитории: не показать статус,
              а дать человеку пространство, где можно жить в тишине, приватности и внутреннем масштабе.
            </p>
            <div class="immersive745__facts">
              <span>Приватный формат для взрослой аудитории</span>
              <span>Спокойный городской ритм</span>
              <span>Архитектура без визуального шума</span>
              <span>Дом для самостоятельных и состоявшихся</span>
            </div>
          </div>
        </div>
      </section>

      <section class="section responses745 section--photo-soft" style={`--section-bg: url(${images.aha2})`}>
        <div class="responses745__veil"></div>
        <div class="container responses745__container">
          <div class="section745-heading center745 section745-heading--light">
            <h2>Как «Эндемик» отвечает на то, что обычно останавливает взрослого самостоятельного покупателя</h2>
          </div>
          <div class="responses745__stack">
            {responseCards.map((card) => (
              <article class="response745-card">
                <div class="response745-card__media">
                  <img src={card.image} alt={card.alt} loading="lazy" />
                </div>
                <div class="response745-card__body">
                  <div class="response745-card__number">{card.number}</div>
                  <h3>{card.title}</h3>
                  <p class="response745-card__problem">{card.problem}</p>
                  <p>{card.answer}</p>
                  <p class="response745-card__detail">{card.detail}</p>
                  {card.cta && (
                    <a class="inline-link745" href="#contact">{card.cta}</a>
                  )}
                </div>
              </article>
            ))}
          </div>
        </div>
      </section>

      <section class="split-photo745">
        <div class="split-photo745__image" style={`--split-bg: url(${images.qualifier})`}></div>
        <div class="split-photo745__content-wrap">
          <div class="container split-photo745__container">
            <div class="split-photo745__content">
              <p class="immersive745__eyebrow">ЖК «Эндемик» · Узнайте себя</p>
              <h2>Этот дом — для тех, кто больше не хочет жить в навязанном городом сценарии</h2>
              <div class="self745 self745--transparent">
                {selfSelection.map((item) => <p>{item}</p>)}
              </div>
              <blockquote class="quote745 quote745--light">
                <p>
                  «Сильный девелоперский лендинг в этом сегменте должен обещать не метры и не статус, а редкое совпадение дома
                  с внутренним устройством человека. Именно так появляется ощущение: это место — про меня.»
                </p>
                <footer>Подход к переупаковке позиционирования Эндемика</footer>
              </blockquote>
            </div>
          </div>
        </div>
      </section>

      <section class="section section--photo-band life745" style={`--section-bg: url(${images.compare})`}>
        <div class="section-band745__overlay section-band745__overlay--dark"></div>
        <div class="container life745__container">
          <div class="section745-heading section745-heading--light center745">
            <p class="immersive745__eyebrow">ЖК «Эндемик» · Формат дома</p>
            <h2>Сравните типовой бизнес-класс и тот образ жизни, который должен собирать «Эндемик»</h2>
          </div>
          <div class="responses745__stack responses745__stack--three">
            {comparisons.map((item) => (
              <article class="comparison745-card comparison745-card--overlay">
                <div class="comparison745-card__overline">{item.overline}</div>
                <h3>{item.title}</h3>
                <p>{item.text}</p>
              </article>
            ))}
          </div>
          <div class="life745-table-wrap">
            <table class="life745-table">
              <thead>
                <tr>
                  <th>Фокус</th>
                  <th>На кого работает</th>
                  <th>Что человек хочет получить</th>
                  <th>Как это должно звучать в лендинге</th>
                </tr>
              </thead>
              <tbody>
                {lifeStages.map((item) => (
                  <tr>
                    <td>
                      <strong>{item.stage}</strong>
                      <span>{item.price}</span>
                    </td>
                    <td>{item.who}</td>
                    <td>{item.hire}</td>
                    <td>{item.format}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
          <div class="action745-wrap center745">
            <a href="#contact" class="button745 button745--secondary">Обсудить структуру лендинга</a>
          </div>
        </div>
      </section>

      <section class="immersive745" style={`--immersive-bg: url(${images.evolution})`}>
        <div class="container immersive745__inner immersive745__inner--right">
          <div class="immersive745__card immersive745__card--single-story">
            <article class="story745-card">
              <div class="story745-card__number">01</div>
              <h2>От «достойного проекта» — к редкому дому для конкретного сегмента</h2>
              <p class="story745-card__problem">
                Пока проект звучит слишком общо, он остаётся в поле сравнения по формальным признакам. Взрослая самостоятельная аудитория
                не узнаёт в нём свой образ жизни — и не доходит до заявки.
              </p>
              <p>
                Задача переупаковки — собрать из архитектуры, локации, камерности и интонации цельный сценарий жизни, в котором человек
                узнаёт себя без дополнительных объяснений.
              </p>
              <a class="inline-link745" href="#contact">Перейти к финальному экрану</a>
            </article>
          </div>
        </div>
      </section>

      <section class="section process745 section--photo-band" style={`--section-bg: url(${images.footer})`}>
        <div class="section-band745__overlay"></div>
        <div class="container process745__container">
          <div class="section745-heading section745-heading--light center745">
            <h2>Как мы доводим Эндемик до лендинга уровня 745 — уже под нужный сегмент</h2>
          </div>
          <div class="process745__grid process745__grid--stacked">
            {processSteps.map((step) => (
              <article class="process745-card process745-card--stacked process745-card--light">
                <div class="process745-card__number">{step.number}</div>
                <div>
                  <h3>{step.title}</h3>
                  <p>{step.description}</p>
                </div>
              </article>
            ))}
          </div>
        </div>
      </section>

      <section id="contact" class="section final745 final745--photo">
        <div class="final745__backdrop" style={`--section-bg: url(${images.footer})`}></div>
        <div class="container final745__container">
          <div class="final745__layout">
            <div class="final745__content">
              <p class="final745__eyebrow">ЖК «Эндемик» · Следующий шаг</p>
              <h2>Готовы увидеть, как может выглядеть новая версия лендинга</h2>
              <p class="final745__lead">
                Слева — текущий экран позиционирования. Справа — форма для встречи, на которой разберём, как перевести Эндемик
                в более точную коммуникацию для сегмента «Одинокие и состоявшиеся».
              </p>
              <div class="final745__visual-card">
                <img src={images.currentPositioning} alt="Текущий экран позиционирования ЖК Эндемик" loading="lazy" />
              </div>
            </div>

            <div class="final745__card">
              <form
                name={formName}
                method="POST"
                data-netlify="true"
                netlify-honeypot="bot-field"
                action="/thank-you"
                class="final745__form"
              >
                <input type="hidden" name="form-name" value={formName} />
                <input type="hidden" name="landing_slug" value={slug} />
                <input type="hidden" name="utm_source" />
                <input type="hidden" name="utm_medium" />
                <input type="hidden" name="utm_campaign" />
                <input type="hidden" name="utm_content" />
                <input type="hidden" name="utm_term" />
                <p class="hidden">
                  <label>
                    Не заполняйте это поле, если вы человек
                    <input name="bot-field" />
                  </label>
                </p>

                <div class="final745__form-copy">
                  <h3 class="final745__form-title">Назначить встречу по переупаковке</h3>
                  <p>
                    Обсудим, какие блоки, визуальные акценты и формулировки помогут собрать из Эндемика лендинг,
                    который действительно цепляет нужный сегмент.
                  </p>
                </div>

                <div class="final745__fields">
                  <div class="final745__field-block final745__form-full">
                    <label for="name" class="field-label745">Имя</label>
                    <input type="text" id="name" name="name" required class="field-input745" />
                  </div>
                  <div class="final745__field-block final745__form-full">
                    <label for="phone" class="field-label745">Телефон / Telegram</label>
                    <input type="tel" id="phone" name="phone" required class="field-input745" />
                  </div>
                  <div class="final745__field-block final745__form-full">
