---
import Layout from '../layouts/Layout.astro';
import { Analytics } from '../utils/analytics';
import '../styles/global.css';

const slug = "syndication-krt";
const formName = "contact-syndication-krt";

const hero = {
  label: 'ДЛЯ ВЛАДЕЛЬЦЕВ УЧАСТКОВ КРТ ОТ 20 ГА',
  title: 'Правильная нарезка КРТ даёт премию к земле и 0% долга',
  lead: 'Мы не просто рисуем мастер-план. Мы структурируем территорию как портфель инвестиционных лотов, которые понятны рынку и банкам. Вы сохраняете контроль над обликом района, делегируя стройку профильным игрокам.',
  image: '/assets/aesthetes/original/hero_hero.jpg',
  cta: 'Обсудить потенциал участка'
};

const triggers = [
  { title: 'Премия к земле', description: 'Упакованные лоты продаются на 30–40% дороже, чем сырая территория целиком.' },
  { title: '0% долга', description: 'Продажа первых лотов закрывает затраты на сети и социалку без банковских кредитов.' },
  { title: 'Контроль облика', description: 'Единый дизайн-код и юридическая обвязка гарантируют качество застройки.' },
  { title: 'Скорость сделок', description: 'Готовая концепция и ТЭПы сокращают цикл продажи лота до 3–4 месяцев.' }
];

const process = {
  eyebrow: 'КАК МЫ ЭТО ДЕЛАЕМ',
  title: 'От сырого участка — до портфеля сделок',
  image: '/assets/aesthetes/original/process_bg.jpg',
  steps: [
    { id: '01', title: 'Аудит территории', description: 'Анализируем участок, ВРИ, ограничения. Определяем оптимальный набор функций.' },
    { id: '02', title: 'Мастер-план', description: 'Нарезаем территорию на лоты с учётом синергии. Разрабатываем дизайн-код.' },
    { id: '03', title: 'Упаковка лотов', description: 'Считаем ТЭПы, финмодель, готовим юридическую схему (SPV/субаренда).' },
    { id: '04', title: 'Брокеридж', description: 'Находим профильных застройщиков на каждый лот и закрываем сделки.' }
  ]
};

const responses = [
  {
    id: '01',
    title: 'Мультипликативный мастер-план',
    italic: '«Если просто нарезать землю на квадраты — получится спальник без синергии».',
    description: 'Мы создаём мастер-план, где лоты взаимоувязаны: школа повышает цену жилья, жильё даёт трафик коммерции, парк увеличивает стоимость всех прилегающих лотов.',
    detail: 'Застройщики платят премию за понятную концепцию и гарантированную синергию.',
    image: '/assets/aesthetes/original/response_01.jpg',
    cta: 'Посмотреть примеры'
  },
  {
    id: '02',
    title: 'Упаковка лотов под типы девелоперов',
    italic: '«Как нарезать территорию, чтобы каждый кусок был интересен конкретному типу застройщика?»',
    description: 'Мы знаем требования разных типов девелоперов: премиум-жильё, масс-маркет, коммерция, социалка. Каждый лот упаковывается как готовый инвест-продукт.',
    detail: 'Лот продаётся с ТЭПами, финмоделью, юрсхемой (SPV/субаренда) и профилем целевого девелопера.',
    image: '/assets/aesthetes/original/response_02.jpg',
    cta: 'Узнать подробнее'
  },
  {
    id: '03',
    title: 'Единый дизайн-код территории',
    italic: '«Разные застройщики построят кто во что горазд — лоскутное одеяло».',
    description: 'Мы разрабатываем дизайн-код и юридически закрепляем его в договорах с каждым партнёром.',
    detail: 'Вы сохраняете контроль над обликом района, не занимаясь операционной стройкой.',
    image: '/assets/aesthetes/original/response_03.jpg',
    cta: 'Обсудить контроль'
  }
];

const qualifier = {
  eyebrow: 'ДЛЯ КОГО ЭТОТ ПРОДУКТ',
  title: 'Для владельцев крупных участков, которые хотят максимизировать стоимость земли',
  image: '/assets/aesthetes/original/qualifier_bg.jpg',
  bullets: [
    'Вы подписали договор КРТ на крупный участок, но не планируете застраивать его самостоятельно — ищете способ максимизировать стоимость земли.',
    'Вы пытались продать территорию целиком, но покупатели требуют огромный дисконт за риск освоения.',
    'Вы хотите создать знаковый район, но понимаете: для этого нужны лучшие профильные игроки на каждый тип застройки.'
  ],
  quote: '«У нас 50 гектаров по договору КРТ. Строить самим — заморозить компанию на 15 лет. Продать целиком — потерять половину стоимости. Нужен кто-то, кто поможет нарезать, упаковать и продать по частям».',
  context: 'Контекст крупного регионального девелопера · 2026',
  cta: 'Обсудить ваш участок'
};

const immersiveStory = {
  title: 'Как это уже работает на рынке',
  description: 'Владелец территории не строит сам — он структурирует проект под рынок.',
  points: [
    '«ЯрПарк» в Казани (300 тыс. кв. м) — PowerChina как генподрядчик и соинвестор. Unikey выкупил у ПИК 51% в проекте КРТ в Москве.',
    '«Самолёт» передал «Бруснике» часть «Егорово парк» через SPV.',
    'DevPartners помогает делать это системно: от аудита территории до закрытия сделок с профильными застройщиками.'
  ],
  image: '/assets/aesthetes/original/immersive_bg.jpg',
  cta: 'Обсудить ваш участок'
};

const comparisons = {
  eyebrow: 'ЧЕМ СТРУКТУРИРОВАНИЕ ОТЛИЧАЕТСЯ ОТ АЛЬТЕРНАТИВ',
  title: 'Почему стандартный подход не работает для масштабных КРТ',
  items: [
    {
      overtitle: 'РОЗНИЦА ПРОТИВ ОПТА',
      title: 'Продажа с премией, а не с дисконтом',
      description: 'Продажа участка целиком — дисконт 30–40%. Нарезка на упакованные лоты — розничная продажа с премией за концепцию и синергию.'
    },
    {
      overtitle: 'ВИЗИОНЕР ПРОТИВ ПРОРАБА',
      title: 'Управление капитализацией, а не стройкой',
      description: 'Застройка 100 га — 15 лет кассовых разрывов. Структурирование позволяет управлять стоимостью актива, делегируя стройку профильным игрокам.'
    },
    {
      overtitle: 'СИНЕРГИЯ ПРОТИВ ХАОСА',
      title: 'Мультипликативный эффект вместо лоскутного одеяла',
      description: 'Мастер-план, где каждый лот повышает ценность соседних. Школа поднимает цену жилья. Жильё даёт трафик коммерции. Парк увеличивает стоимость всего.'
    }
  ]
};

const teamMembers = [
  {
    name: 'Дамир Хайров',
    photo: '/assets/syndication-krt/team-damir-new.webp',
    description: 'Исследует покупательские сценарии по методологии DTBD и адаптирует концепцию лотов под российский контекст. Формирует техническое задание так, чтобы каждый партнёр понял задачу с первого дня. Отвечает за то, чтобы каждый лот КРТ решал реальную задачу рынка и соответствовал требованиям города, банка и регулятора.',
  },
  {
    name: 'Андрей Пахоменков',
    photo: '/assets/syndication-krt/team-andrey.jpg',
    description: 'Обосновывает финансовую модель каждого лота и готовит пакет для кредитного комитета. Формирует упаковку для управляющих компаний и материалы для инвесторов. Переводит архитектурные и продуктовые решения в язык, понятный банку и фонду.',
  },
  {
    name: 'Рамзия Фаздалова',
    photo: '/assets/syndication-krt/team-ramzia.jpg',
    description: 'Переговорный стратег в работе с иностранными и нестандартными партнёрами. Понимает культурный контекст и выстраивает коммуникацию так, чтобы партнёр хотел работать с нами. Переводит технические задания и протоколы без потерь смысла.',
  },
];
---

<Layout title="Структурирование КРТ под рынок — премия к земле и 0% долга — DevPartners">
  <main>
    {/* HERO SECTION */}
    <section class="hero">
      <div class="hero-bg">
        <img src={hero.image} alt="" />
        <div class="hero-overlay"></div>
      </div>
      <div class="container">
        <div class="hero-content">
          <div class="hero-label">{hero.label}</div>
          <h1>{hero.title}</h1>
          <p class="lead">{hero.lead}</p>
          
          <div class="hero-triggers">
            {triggers.map(t => (
              <div class="trigger-card">
                <h3>{t.title}</h3>
                <p>{t.description}</p>
              </div>
            ))}
          </div>

          <a href="#final-form" class="btn btn-primary">{hero.cta}</a>
        </div>
      </div>
    </section>

    {/* PROCESS SECTION */}
    <section class="process">
      <div class="process-bg">
        <img src={process.image} alt="" />
        <div class="process-overlay"></div>
      </div>
      <div class="container">
        <div class="section-header text-center">
          <div class="eyebrow">{process.eyebrow}</div>
          <h2>{process.title}</h2>
        </div>
        <div class="process-grid">
          {process.steps.map(step => (
            <div class="process-card">
              <div class="step-id">{step.id}</div>
              <h3>{step.title}</h3>
              <p>{step.description}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    {/* RESPONSES SECTION */}
    <section class="responses">
      <div class="container">
        <div class="section-header text-center">
          <h2>Как мы решаем три ключевые задачи</h2>
        </div>
        <div class="responses-list">
          {responses.map(r => (
            <div class="response-card">
              <div class="response-image">
                <img src={r.image} alt={r.title} />
              </div>
              <div class="response-content">
                <div class="step-id">{r.id}</div>
                <h3>{r.title}</h3>
                <p class="italic">{r.italic}</p>
                <p class="description">{r.description}</p>
                <p class="detail">{r.detail}</p>
                <a href="#final-form" class="inline-cta">{r.cta}</a>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    {/* QUALIFIER SECTION */}
    <section class="qualifier">
      <div class="qualifier-bg">
        <img src={qualifier.image} alt="" />
        <div class="qualifier-overlay"></div>
      </div>
      <div class="container">
        <div class="qualifier-grid">
          <div class="qualifier-image-side">
            {/* Empty, background image shows here */}
          </div>
          <div class="qualifier-content">
            <div class="eyebrow">{qualifier.eyebrow}</div>
            <h2>{qualifier.title}</h2>
            <ul class="bullets">
              {qualifier.bullets.map(b => <li>{b}</li>)}
            </ul>
            <div class="quote-box">
              <p>{qualifier.quote}</p>
              <div class="quote-context">{qualifier.context}</div>
            </div>
            <a href="#final-form" class="btn btn-primary">{qualifier.cta}</a>
          </div>
        </div>
      </div>
    </section>

    {/* IMMERSIVE STORY */}
    <section class="immersive">
      <div class="immersive-bg">
        <img src={immersiveStory.image} alt="" />
        <div class="immersive-overlay"></div>
      </div>
      <div class="container">
        <div class="immersive-card">
          <h2>{immersiveStory.title}</h2>
          <p class="lead">{immersiveStory.description}</p>
          <div class="story-points">
            {immersiveStory.points.map(p => <p>{p}</p>)}
          </div>
          <a href="#final-form" class="btn btn-ghost">{immersiveStory.cta}</a>
        </div>
      </div>
    </section>

    {/* COMPARISONS SECTION */}
    <section class="comparisons">
      <div class="container">
        <div class="section-header text-center">
          <div class="eyebrow">{comparisons.eyebrow}</div>
          <h2>{comparisons.title}</h2>
        </div>
        <div class="comparisons-grid">
          {comparisons.items.map(item => (
            <div class="comparison-card">
              <div class="overtitle">{item.overtitle}</div>
              <h3>{item.title}</h3>
              <p>{item.description}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    {/* TEAM SECTION */}
    <section class="team">
      <div class="container">
        <div class="section-header text-center">
          <h2>Команда</h2>
          <p class="sub">Люди, которые ведут проект с первого звонка до результата</p>
        </div>
        <div class="team-grid">
          {teamMembers.map(member => (
            <div class="team-card">
              <div class="team-photo">
                <img src={member.photo} alt={member.name} />
              </div>
              <div class="team-info">
                <h3>{member.name}</h3>
                <p>{member.description}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    {/* LIFE STAGES TABLE */}
    <section class="life-stages">
      <div class="container">
        <div class="section-header text-center">
          <h2>Когда владельцу КРТ нужен партнёр по структурированию</h2>
          <p class="sub">Этот продукт нанимают в конкретный момент — когда строить всё самому перестаёт быть рациональным.</p>
        </div>
        <div class="table-wrapper">
          <table>
            <thead>
              <tr>
                <th>ЭТАП</th>
                <th>КТО ВЫ СЕЙЧАС</th>
                <th>ЧТО ВЫ НАНИМАЕТЕ</th>
                <th>ФОРМАТ ПРОЕКТА</th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <td><strong>Банк не даёт денег на весь КРТ</strong><br/><small>ФИНАНСОВЫЙ ТУПИК</small></td>
                <td>Долговая нагрузка на весь проект запредельная.</td>
                <td>Нарезку территории и продажу части нагрузки профильным девелоперам.</td>
                <td>Аудит → Лотовая карта → Упаковка → Брокеридж.</td>
              </tr>
              <tr>
                <td><strong>Оптом — только с дисконтом</strong><br/><small>ПОТЕРЯ ПРИБЫЛИ</small></td>
                <td>Покупатели готовы забрать весь участок, но просят скидку 30–40%.</td>
                <td>Розничную продажу лотов с премией за концепцию и синергию.</td>
                <td>Мастер-план → Упаковка → Сделки.</td>
              </tr>
              <tr>
                <td><strong>Не хватает компетенций</strong><br/><small>РИСК КАЧЕСТВА</small></td>
                <td>Нужна сложная коммерция, социалка, Light Industrial.</td>
                <td>Привлечение профильных игроков на непрофильные лоты.</td>
                <td>Выделение лотов → Упаковка → Подбор партнёров.</td>
              </tr>
              <tr>
                <td><strong>Хотите лучший район в городе</strong><br/><small>СТРАТЕГИЧЕСКИЙ ВЫБОР</small></td>
                <td>Хотите управлять проектом на уровне стратегии.</td>
                <td>Мультипликативный мастер-план и единый дизайн-код.</td>
                <td>Мастер-план → Дизайн-код → Юрструктурирование.</td>
              </tr>
            </tbody>
          </table>
        </div>
        <div class="text-center mt-4">
          <a href="#final-form" class="btn btn-primary">Обсудить мой случай</a>
        </div>
      </div>
    </section>

    {/* FINAL FORM SECTION */}
    <section id="final-form" class="final-form">
      <div class="container">
        <div class="form-grid">
          <div class="form-content">
            <div class="eyebrow">ДИАГНОСТИКА УЧАСТКА</div>
            <h2>Расскажите о вашем участке — покажем, как нарезка увеличит прибыль</h2>
            <div class="positioning-image">
              <img src="/assets/syndication-krt/current_positioning.png" alt="Схема структурирования" />
            </div>
          </div>
          <div class="form-card">
            <div class="eyebrow">ПЕРВЫЙ ШАГ</div>
            <h3>Обсудить структурирование</h3>
            <p class="sub">Опишите участок: площадь, локация, текущий статус КРТ.</p>
            <form action="#" method="POST" class="contact-form" data-form-name={formName}>
              <div class="form-group">
                <label for="name">ИМЯ</label>
                <input type="text" id="name" name="name" required />
              </div>
              <div class="form-group">
                <label for="phone">ТЕЛЕФОН / TELEGRAM</label>
                <input type="tel" id="phone" name="phone" required />
              </div>
              <div class="form-group">
                <label for="email">EMAIL</label>
                <input type="email" id="email" name="email" required />
              </div>
              <button type="submit" class="btn btn-primary w-full">Записаться на встречу</button>
            </form>
          </div>
        </div>
      </div>
    </section>
  </main>
</Layout>

<style>
  :root {
    --primary: #c5a47e;
    --primary-dark: #a38662;
    --text-dark: #1a1a1a;
    --text-mid: #4a4a4a;
    --text-light: #f6efe8;
    --bg-light: #f6efe8;
    --bg-dark: #1a1a1a;
    --glass: rgba(255, 255, 255, 0.1);
    --glass-border: rgba(255, 255, 255, 0.2);
  }

  section {
    padding: 100px 0;
    position: relative;
    overflow: hidden;
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 20px;
  }

  .text-center { text-align: center; }
  .mt-4 { margin-top: 40px; }
  .w-full { width: 100%; }

  .eyebrow {
    font-size: 0.78rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--primary);
    margin-bottom: 1.5rem;
    font-weight: 600;
  }

  h1 { font-size: 4.6rem; line-height: 1.1; margin-bottom: 2rem; font-family: 'Unbounded', sans-serif; font-weight: 700; }
  h2 { font-size: 3rem; line-height: 1.2; margin-bottom: 2rem; font-family: 'Unbounded', sans-serif; font-weight: 700; }
  h3 { font-size: 1.4rem; line-height: 1.4; margin-bottom: 1rem; font-family: 'Unbounded', sans-serif; font-weight: 700; }
  p { font-size: 1.05rem; line-height: 1.6; color: var(--text-mid); }
  .lead { font-size: 1.25rem; line-height: 1.6; margin-bottom: 2.5rem; }

  .btn {
    display: inline-block;
    padding: 1.2rem 2.5rem;
    border-radius: 100px;
    font-weight: 600;
    text-decoration: none;
    transition: all 0.3s ease;
    cursor: pointer;
    border: none;
    font-family: 'Inter', sans-serif;
    font-size: 1rem;
  }

  .btn-primary {
    background: var(--primary);
    color: white;
  }

  .btn-primary:hover {
    background: var(--primary-dark);
    transform: translateY(-2px);
  }

  .btn-ghost {
    background: transparent;
    border: 1px solid white;
    color: white;
  }

  .btn-ghost:hover {
    background: white;
    color: var(--bg-dark);
  }

  /* HERO */
  .hero {
    min-height: 100vh;
    display: flex;
    align-items: center;
    color: white;
    padding-top: 140px;
  }

  .hero-bg {
    position: absolute;
    top: 0; left: 0; width: 100%; height: 100%;
    z-index: -1;
  }

  .hero-bg img { width: 100%; height: 100%; object-fit: cover; }
  .hero-overlay {
    position: absolute;
    top: 0; left: 0; width: 100%; height: 100%;
    background: linear-gradient(to bottom, rgba(0,0,0,0.7), rgba(0,0,0,0.5));
  }

  .hero-content { max-width: 900px; }
  .hero-content h1 { color: white; }
  .hero-content .lead { color: rgba(255,255,255,0.9); }

  .hero-triggers {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 20px;
    margin-bottom: 40px;
  }

  .trigger-card {
    background: var(--glass);
    backdrop-filter: blur(10px);
    border: 1px solid var(--glass-border);
    padding: 25px;
    border-radius: 16px;
  }

