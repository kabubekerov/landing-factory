---
<AesthetesTemplate
  slug={slug}
  formName={formName}
  meta={meta}
  images={images}
  hero={hero}
  triggerPoints={triggerPoints}
  selfSelection={selfSelection}
  responseCards={responseCards}
  lifeStages={lifeStages}
  processSteps={processSteps}
  comparisons={comparisons}
  sections={sections}
/>
