---
import AesthetesTemplate from '../templates/AesthetesTemplate.astro';
const slug = 'syndication-krt';
const formName = `landing-syndication-krt`;
const meta = {"title": "Структурирование КРТ под рынок — премия к земле и 0% долга — DevPartners", "description": "DevPartners помогает владельцам участков КРТ нарезать территорию на лоты под профильных застройщиков. Правильная нарезка даёт премию к земле и снижает долговую нагрузку до нуля."};
const images = {"hero": "/assets/syndication-krt/hero_hero.jpg", "aha1": "/assets/syndication-krt/aha1_architecture.jpg", "aha2": "/assets/syndication-krt/aha2_materials.jpg", "aha3": "/assets/syndication-krt/aha3_courtyard.jpg", "qualifier": "/assets/syndication-krt/qualifier_who.jpg", "evolution": "/assets/syndication-krt/evolution_levels.jpg", "compare": "/assets/syndication-krt/advantages_compare.jpg", "footer": "/assets/syndication-krt/footer_cta.jpg", "currentPositioning": "/assets/syndication-krt/current_positioning.png"};

// Увеличиваем шрифт lead через инлайн-стиль, так как CSS общий
const hero = {
  "label": "Для владельцев участков КРТ от 20 га", 
  "h1": "Правильная нарезка КРТ даёт премию к земле и 0% долга", 
  "lead": "<span style='font-size: 1.25em; line-height: 1.6; display: block;'>Структурируем территорию на лоты под профильных девелоперов. Каждый лот — готовый инвест-продукт. Каждый партнёр усиливает соседний лот. Вы получаете премию за землю без операционной стройки.</span>", 
  "offerLine": "Аудит · Мастер-план · Упаковка лотов · Брокеридж", 
  "ctaText": "Обсудить потенциал участка", 
  "cardH2": "Архитектор КРТ-партнёрств", 
  "cardMeta": "DevPartners · B2B для лендлордов", 
  "cardBody": "От градостроительного аудита до подписания договоров с профильными застройщиками. Вы управляете капитализацией, а не стройкой."
};

// Триггеры теперь будут выводиться сразу под hero (блок 1 по DTBD)
const triggerPoints = [
  "Финансовый тупик: банк не финансирует застройку всего КРТ одним девелопером, долговая нагрузка запредельная.", 
  "Дисконт при продаже оптом: покупатели готовы забрать весь участок, но требуют скидку 30–40% за риск освоения.", 
  "Нехватка компетенций: на территории нужны разные типы недвижимости (жильё, коммерция, социалка), но у вас нет опыта во всех сегментах.",
  "Стратегический выбор: вы хотите управлять проектом на уровне капитализации, а не закапываться в котлованы на 15 лет."
];

// Блок 2 по DTBD: Готовое решение (4 шага процесса). В шаблоне Aesthetes он выводится ниже, 
// но мы можем использовать блок immersive1 для вывода процесса сразу после триггеров.
const sections = {
  "immersive1": {
    "eyebrow": "Как мы это делаем", 
