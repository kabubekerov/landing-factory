---
import Analytics from '../components/Analytics.astro';
import '../styles/global.css';

const slug = 'syndication-krt';
const formName = `landing-syndication-krt`;

const meta = {
  title: 'Структурирование КРТ под рынок — премия к земле и 0% долга — DevPartners',
  description: 'DevPartners помогает владельцам участков КРТ нарезать территорию на лоты под профильных застройщиков. Правильная нарезка даёт премию к земле и снижает долговую нагрузку до нуля.',
};

const images = {
  hero: '/assets/syndication-krt/hero_hero.jpg',
  aha1: '/assets/syndication-krt/aha1_architecture.jpg',
  aha2: '/assets/syndication-krt/aha2_materials.jpg',
  aha3: '/assets/syndication-krt/aha3_courtyard.jpg',
  qualifier: '/assets/syndication-krt/qualifier_who.jpg',
  compare: '/assets/syndication-krt/advantages_compare.jpg',
  evolution: '/assets/syndication-krt/evolution_levels.jpg',
  footer: '/assets/syndication-krt/footer_cta.jpg',
  currentPositioning: '/assets/syndication-krt/current_positioning.png',
};

const triggerPoints = [
  '<strong>Финансовый тупик:</strong> банк не финансирует застройку всего КРТ одним девелопером.',
  '<strong>Дисконт при продаже оптом:</strong> покупатели требуют скидку 30–40% за риск освоения.',
  '<strong>Нехватка компетенций:</strong> на территории нужны разные типы недвижимости, но у вас нет опыта во всех сегментах.',
  '<strong>Стратегический выбор:</strong> вы хотите управлять капитализацией, а не стройкой на 15 лет.',
];

const processSteps = [
  { number: '01', title: 'Аудит территории', text: 'Анализируем участок, ВРИ, ограничения. Определяем оптимальный набор функций.' },
  { number: '02', title: 'Мастер-план', text: 'Нарезаем территорию на лоты с учётом синергии. Разрабатываем дизайн-код.' },
  { number: '03', title: 'Упаковка лотов', text: 'Считаем ТЭПы, финмодель, готовим юридическую схему (SPV/субаренда).' },
  { number: '04', title: 'Брокеридж', text: 'Находим профильных застройщиков на каждый лот и закрываем сделки.' },
];

const responseCards = [
  {
    number: '01',
    title: 'Мультипликативный мастер-план',
    problem: '«Если просто нарезать землю на квадраты — получится спальник без синергии».',
    answer: 'Мы создаём мастер-план, где лоты взаимоувязаны: школа повышает цену жилья, жильё даёт трафик коммерции, парк увеличивает стоимость всех прилегающих лотов.',
    detail: 'Застройщики платят премию за понятную концепцию и гарантированную синергию.',
    cta: 'Посмотреть примеры',
    image: images.aha1,
    alt: 'Мультипликативный мастер-план территории КРТ',
  },
  {
    number: '02',
    title: 'Упаковка лотов под типы девелоперов',
    problem: '«Как нарезать территорию, чтобы каждый кусок был интересен конкретному типу застройщика?»',
    answer: 'Мы знаем требования разных типов девелоперов: премиум-жильё, масс-маркет, коммерция, социалка. Каждый лот упаковывается как готовый инвест-продукт.',
    detail: 'Лот продаётся с ТЭПами, финмоделью, юрсхемой (SPV/субаренда) и профилем целевого девелопера.',
    cta: 'Узнать подробнее',
    image: images.aha2,
    alt: 'Упаковка лотов КРТ под профильных девелоперов',
  },
  {
    number: '03',
    title: 'Единый дизайн-код территории',
    problem: '«Разные застройщики построят кто во что горазд — лоскутное одеяло».',
    answer: 'Мы разрабатываем дизайн-код и юридически закрепляем его в договорах с каждым партнёром.',
    detail: 'Вы сохраняете контроль над обликом района, не занимаясь операционной стройкой.',
    cta: 'Обсудить контроль',
    image: images.aha3,
    alt: 'Единый дизайн-код территории КРТ',
  },
];

const selfSelection = [
  'Вы подписали договор КРТ на крупный участок, но не планируете застраивать его самостоятельно — ищете способ максимизировать стоимость земли.',
  'Вы пытались продать территорию целиком, но покупатели требуют огромный дисконт за риск освоения.',
  'Вы хотите создать знаковый район, но понимаете: для этого нужны лучшие профильные игроки на каждый тип застройки.',
];

const comparisons = [
  {
    overline: 'Розница против опта',
    title: 'Продажа с премией, а не с дисконтом',
    text: 'Продажа участка целиком — дисконт 30–40%. Нарезка на упакованные лоты — розничная продажа с премией за концепцию и синергию.',
  },
  {
    overline: 'Визионер против прораба',
    title: 'Управление капитализацией, а не стройкой',
    text: 'Застройка 100 га — 15 лет кассовых разрывов. Структурирование позволяет управлять стоимостью актива, делегируя стройку профильным игрокам.',
  },
  {
    overline: 'Синергия против хаоса',
    title: 'Мультипликативный эффект вместо лоскутного одеяла',
    text: 'Мастер-план, где каждый лот повышает ценность соседних. Школа поднимает цену жилья. Жильё даёт трафик коммерции. Парк увеличивает стоимость всего.',
  },
];

const lifeStages = [
  {
    stage: 'Банк не даёт денег на весь КРТ',
    price: 'Финансовый тупик',
    who: 'Долговая нагрузка на весь проект запредельная.',
    hire: 'Нарезку территории и продажу части нагрузки профильным девелоперам.',
    format: 'Аудит → Лотовая карта → Упаковка → Брокеридж.',
  },
  {
    stage: 'Оптом — только с дисконтом',
    price: 'Потеря прибыли',
    who: 'Покупатели готовы забрать весь участок, но просят скидку 30–40%.',
    hire: 'Розничную продажу лотов с премией за концепцию и синергию.',
    format: 'Мастер-план → Упаковка → Сделки.',
  },
  {
    stage: 'Не хватает компетенций',
    price: 'Риск качества',
    who: 'Нужна сложная коммерция, социалка, Light Industrial.',
    hire: 'Привлечение профильных игроков на непрофильные лоты.',
    format: 'Выделение лотов → Упаковка → Подбор партнёров.',
  },
  {
    stage: 'Хотите лучший район в городе',
    price: 'Стратегический выбор',
    who: 'Хотите управлять проектом на уровне стратегии.',
    hire: 'Мультипликативный мастер-план и единый дизайн-код.',
    format: 'Мастер-план → Дизайн-код → Юрструктурирование.',
  },
];

const teamMembers = [
  {
    name: 'Дамир Хайров',
    photo: '/assets/syndication-krt/team-damir.webp',
    description: 'Исследует покупательские сценарии и потребности конечных клиентов по методологии DTBD. Переводит результаты в качественное техническое задание: кто покупает, зачем, что для него важно. Отвечает за то, чтобы каждый лот КРТ решал реальную задачу рынка, а не воображаемую.',
  },
  {
    name: 'Алмаз Шакиров',
    photo: '/assets/syndication-krt/team-almaz.jpg',
    description: 'Отвечает за адаптацию мастер-плана и концепции лотов под российский контекст. Формирует техническое задание так, чтобы каждый партнёр понял задачу с первого дня. Контролирует, чтобы результат прошёл все согласования и соответствовал требованиям города, банка и регулятора.',
  },
  {
    name: 'Андрей Пахоменков',
    photo: '/assets/syndication-krt/team-andrey.jpg',
    description: 'Обосновывает финансовую модель каждого лота и готовит пакет для кредитного комитета. Формирует упаковку для управляющих компаний и материалы для инвесторов. Переводит архитектурные и продуктовые решения в язык, понятный банку и фонду.',
  },
  {
    name: 'Рамзия Фаздалова',
    photo: '/assets/syndication-krt/team-ramzia.jpg',
    description: 'Переговорный стратег в работе с иностранными и нестандартными партнёрами. Понимает культурный контекст и выстраивает коммуникацию так, чтобы партнёр хотел работать с нами. Переводит технические задания и протоколы без потерь смысла.',
  },
];
---

<html lang="ru">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>{meta.title}</title>
    <meta name="description" content={meta.description} />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
  </head>
  <body class="landing-745">
    <Analytics landingSlug={slug} />

    <main>

      <!-- ═══════════════ HERO + TRIGGERS ON SCREEN ═══════════════ -->
      <section class="krt-hero">
        <div class="krt-hero__backdrop" style={`--hero-bg: url(${images.hero})`}></div>
        <div class="container krt-hero__container">

          <span class="krt-hero__label">Для владельцев участков КРТ от 20 га</span>

          <h1 class="krt-hero__h1">Правильная нарезка КРТ даёт премию к земле и&nbsp;0%&nbsp;долга</h1>

          <p class="krt-hero__lead">Структурируем территорию на лоты под профильных девелоперов. Каждый лот — готовый инвест-продукт. Каждый партнёр усиливает соседний. Вы получаете премию за землю без операционной стройки.</p>

          <div class="krt-hero__triggers">
            {triggerPoints.map((t: string) => (
              <p class="krt-hero__trigger" set:html={t}></p>
            ))}
          </div>

          <div class="krt-hero__actions">
            <a class="krt-btn krt-btn--primary" href="#contact">Обсудить потенциал участка</a>
          </div>

        </div>
      </section>

      <!-- ═══════════════ PROCESS — 4 STEPS ═══════════════ -->
      <section class="krt-process">
        <div class="krt-process__backdrop" style={`--process-bg: url(${images.aha1})`}></div>
        <div class="container krt-process__container">
          <div class="krt-section-heading krt-section-heading--light krt-center">
            <p class="krt-eyebrow">Как мы это делаем</p>
            <h2>От сырого участка — до портфеля сделок</h2>
          </div>
          <div class="krt-process__grid">
            {processSteps.map((step: any) => (
              <article class="krt-process-card">
                <div class="krt-process-card__number">{step.number}</div>
                <h3>{step.title}</h3>
                <p>{step.text}</p>
              </article>
            ))}
          </div>
        </div>
      </section>

      <!-- ═══════════════ RESPONSE CARDS ═══════════════ -->
      <section class="krt-responses">
        <div class="krt-responses__veil"></div>
        <div class="container krt-responses__container" style={`--resp-bg: url(${images.aha2})`}>
          <div class="krt-section-heading krt-section-heading--light krt-center">
            <h2>Как мы решаем три ключевые задачи</h2>
          </div>
          <div class="krt-responses__stack">
            {responseCards.map((card: any) => (
              <article class="krt-response-card">
                <div class="krt-response-card__media">
                  <img src={card.image} alt={card.alt} loading="lazy" />
                </div>
                <div class="krt-response-card__body">
                  <div class="krt-response-card__number">{card.number}</div>
                  <h3>{card.title}</h3>
                  <p class="krt-response-card__problem">{card.problem}</p>
                  <p>{card.answer}</p>
                  <p class="krt-response-card__detail">{card.detail}</p>
                  <a class="krt-inline-link" href="#contact">{card.cta}</a>
                </div>
              </article>
            ))}
          </div>
        </div>
      </section>

      <!-- ═══════════════ SELF-SELECTION / QUALIFIER ═══════════════ -->
      <section class="krt-split">
        <div class="krt-split__image" style={`--split-bg: url(${images.qualifier})`}></div>
        <div class="krt-split__content-wrap">
          <div class="container krt-split__container">
            <div class="krt-split__content">
              <p class="krt-eyebrow">Для кого этот продукт</p>
              <h2>Для владельцев крупных участков, которые хотят максимизировать стоимость земли</h2>
              <div class="krt-self">
                {selfSelection.map((item: string) => <p>{item}</p>)}
              </div>
              <blockquote class="krt-quote">
                <p>«У нас 50 гектаров по договору КРТ. Строить самим — заморозить компанию на 15 лет. Продать целиком — потерять половину стоимости. Нужен кто-то, кто поможет нарезать, упаковать и продать по частям».</p>
                <footer>Контекст крупного регионального девелопера · 2026</footer>
              </blockquote>
            </div>
          </div>
        </div>
      </section>

      <!-- ═══════════════ STORY / IMMERSIVE ═══════════════ -->
      <section class="krt-immersive" style={`--immersive-bg: url(${images.aha3})`}>
        <div class="container krt-immersive__inner">
          <div class="krt-immersive__card">
            <h2>Как это уже работает на рынке</h2>
            <p class="krt-immersive__accent">Владелец территории не строит сам — он структурирует проект под рынок.</p>
            <p>«ЯрПарк» в Казани (300 тыс. кв. м) — PowerChina как генподрядчик и соинвестор. Unikey выкупил у ПИК 51% в проекте КРТ в Москве. «Самолёт» передал «Бруснике» часть «Егорово парк» через SPV.</p>
            <p>DevPartners помогает делать это системно: от аудита территории до закрытия сделок с профильными застройщиками.</p>
            <a class="krt-btn krt-btn--ghost" href="#contact">Обсудить ваш участок</a>
          </div>
        </div>
      </section>

      <!-- ═══════════════ COMPARISONS ═══════════════ -->
      <section class="krt-compare">
        <div class="krt-compare__backdrop" style={`--compare-bg: url(${images.compare})`}></div>
        <div class="container krt-compare__container">
          <div class="krt-section-heading krt-section-heading--light krt-center">
            <p class="krt-eyebrow krt-eyebrow--light">Чем структурирование отличается от альтернатив</p>
            <h2>Почему стандартный подход не работает для масштабных КРТ</h2>
          </div>
          <div class="krt-compare__grid">
            {comparisons.map((comp: any) => (
              <article class="krt-compare-card">
                <div class="krt-compare-card__overline">{comp.overline}</div>
                <h3>{comp.title}</h3>
                <p>{comp.text}</p>
              </article>
            ))}
          </div>
        </div>
      </section>

      <!-- ═══════════════ TEAM ═══════════════ -->
      <section class="krt-team">
        <div class="container krt-team__container">
          <div class="krt-section-heading krt-center">
            <h2>Команда</h2>
            <p class="krt-team__subtitle">Люди, которые ведут проект с первого звонка до результата</p>
          </div>
          <div class="krt-team__grid">
            {teamMembers.map((member: any) => (
              <article class="krt-team-card">
                <div class="krt-team-card__photo-wrap">
                  <img src={member.photo} alt={member.name} loading="lazy" />
                </div>
                <div class="krt-team-card__body">
                  <h3 class="krt-team-card__name">{member.name}</h3>
                  <p class="krt-team-card__desc">{member.description}</p>
                </div>
              </article>
            ))}
          </div>
        </div>
      </section>

      <!-- ═══════════════ LIFE STAGES TABLE ═══════════════ -->
      <section class="krt-life" style={`--life-bg: url(${images.evolution})`}>
        <div class="krt-life__veil"></div>
        <div class="container krt-life__container">
          <div class="krt-section-heading krt-section-heading--light krt-center">
            <h2>Когда владельцу КРТ нужен партнёр по структурированию</h2>
            <p>Этот продукт нанимают в конкретный момент — когда строить всё самому перестаёт быть рациональным.</p>
          </div>
          <div class="krt-life__table-wrap">
            <table class="krt-life-table">
              <thead>
                <tr>
                  <th>Этап</th>
                  <th>Кто вы сейчас</th>
                  <th>Что вы нанимаете</th>
                  <th>Формат проекта</th>
                </tr>
              </thead>
              <tbody>
                {lifeStages.map((item: any) => (
                  <tr>
                    <td>
                      <strong>{item.stage}</strong>
                      <span>{item.price}</span>
                    </td>
                    <td>{item.who}</td>
                    <td>{item.hire}</td>
                    <td>{item.format}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
          <div class="krt-center krt-action-wrap">
            <a class="krt-btn krt-btn--ghost" href="#contact">Обсудить мой случай</a>
          </div>
        </div>
      </section>

      <!-- ═══════════════ FINAL / FORM ═══════════════ -->
      <section id="contact" class="krt-final">
        <div class="krt-final__backdrop" style={`--final-bg: url(${images.footer})`}></div>
        <div class="container krt-final__container">
          <div class="krt-final__layout">
            <div class="krt-final__copy">
              <p class="krt-eyebrow krt-eyebrow--light">Диагностика участка</p>
              <h2>Расскажите о вашем участке — покажем, как нарезка увеличит прибыль</h2>
              <div class="krt-final__shot">
                <img src={images.currentPositioning} alt={`Текущее позиционирование — ${meta.title}`} loading="lazy" />
              </div>
            </div>
            <div class="krt-final__card">
              <p class="krt-eyebrow">Первый шаг</p>
              <h3 class="krt-final__form-title">Обсудить структурирование</h3>
              <p class="krt-final__form-lead">Опишите участок: площадь, локация, текущий статус КРТ.</p>
              <form
                name={formName}
                method="POST"
                data-netlify="true"
                netlify-honeypot="bot-field"
                action="/thank-you"
                class="krt-final__form"
              >
                <input type="hidden" name="form-name" value={formName} />
                <input type="hidden" name="landing_slug" value={slug} />
                <input type="hidden" name="utm_source" value="" />
                <input type="hidden" name="utm_medium" value="" />
                <input type="hidden" name="utm_campaign" value="" />
                <input type="hidden" name="utm_content" value="" />
                <input type="hidden" name="utm_term" value="" />
                <p class="sr-only">
                  <label>Не заполняйте это поле, если вы человек: <input name="bot-field" /></label>
                </p>
                <div class="krt-final__fields">
                  <div class="krt-field">
                    <label for="name">Имя</label>
                    <input type="text" id="name" name="name" required />
                  </div>
                  <div class="krt-field krt-field--full">
                    <label for="phone">Телефон / Telegram</label>
                    <input type="tel" id="phone" name="phone" required />
                  </div>
                  <div class="krt-field krt-field--full">
                    <label for="email">Email</label>
                    <input type="email" id="email" name="email" required />
                  </div>
                </div>
                <button type="submit" class="krt-btn krt-btn--primary krt-btn--full">Записаться на встречу</button>
              </form>
            </div>
          </div>
        </div>
      </section>

    </main>

    <script>
      import { populateUTMFields, trackFormSubmission } from '../utils/analytics.ts';
      (() => {
        const form = document.querySelector('#contact form') as HTMLFormElement | null;
        if (form) {
          populateUTMFields(form);
          form.addEventListener('submit', () => {
            populateUTMFields(form);
            trackFormSubmission('syndication-krt');
          });
        }
      })();
    </script>
  </body>
</html>

<style>
  /* ═══════════════════════════════════════════════════
     KRT LANDING — STANDALONE STYLES
     Full control: no template dependency
     ═══════════════════════════════════════════════════ */

  :global(body.landing-745) {
    background: #0e0b09;
    color: #241b16;
