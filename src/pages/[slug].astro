---
import Offer801Template from '../templates/Offer801Template.astro';
import AesthetesTemplate from '../templates/AesthetesTemplate.astro';
import StayButGrowTemplate from '../templates/StayButGrowTemplate.astro';
import { readFileSync, readdirSync } from 'fs';
import { resolve } from 'path';

export async function getStaticPaths() {
  const dataDir = resolve('./src/data/landings');
  const files = readdirSync(dataDir).filter((f) => f.endsWith('.json'));

  return files.map((file) => {
    const slug = file.replace('.json', '');
    const raw = readFileSync(resolve(dataDir, file), 'utf-8');
    const data = JSON.parse(raw);
    return {
      params: { slug },
      props: { data, slug },
    };
  });
}

const { data, slug } = Astro.props;
const formName = `landing-${slug}`;

const templateType = data.template || 'offer801';
---

{templateType === 'offer801' && (
  <Offer801Template
    slug={slug}
    formName={formName}
    meta={data.meta}
    images={data.images}
    hero={data.hero}
    triggerPoints={data.triggerPoints}
    selfSelection={data.selfSelection}
    responseCards={data.responseCards}
    lifeStages={data.lifeStages}
    processSteps={data.processSteps}
    comparisons={data.comparisons}
    sections={data.sections}
  />
)}

{templateType === 'aesthetes' && (
  <AesthetesTemplate
    slug={slug}
    formName={formName}
    meta={data.meta}
    images={data.images}
    hero={data.hero}
    triggerPoints={data.triggerPoints}
    selfSelection={data.selfSelection}
    responseCards={data.responseCards}
    lifeStages={data.lifeStages}
    processSteps={data.processSteps}
    comparisons={data.comparisons}
    sections={data.sections}
  />
)}

{templateType === 'stay-but-grow' && (
  <StayButGrowTemplate
    slug={slug}
    formName={formName}
    meta={data.meta}
    images={data.images}
    hero={data.hero}
    triggerPoints={data.triggerPoints}
    selfSelection={data.selfSelection}
    responseCards={data.responseCards}
    lifeStages={data.lifeStages}
    processSteps={data.processSteps}
    sections={data.sections}
  />
)}
