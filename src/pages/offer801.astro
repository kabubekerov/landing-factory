---
import Analytics from '../components/Analytics.astro';
import '../styles/global.css';

const slug = 'offer801';
const formName = 'offer801-repack-request';

const images = {
  hero: 'https://d2xsxph8kpxj0f.cloudfront.net/310519663259840902/AXotyppPfFeghR67Uzfaab/offer801-hero-clean-Lqy3vDEe5JDxTYL6dn5xSm.webp',
  aha1: 'https://d2xsxph8kpxj0f.cloudfront.net/310519663259840902/AXotyppPfFeghR67Uzfaab/offer801-courtyard-clean-KqDL6AqqXYREWP6gYVxE9T.webp',
  aha2: 'https://d2xsxph8kpxj0f.cloudfront.net/310519663259840902/AXotyppPfFeghR67Uzfaab/offer801-interior-clean-iWWvJJ96yaYAh4KrVnVRRa.webp',
  aha3: 'https://d2xsxph8kpxj0f.cloudfront.net/310519663259840902/AXotyppPfFeghR67Uzfaab/offer801-green-life-clean-dUMd5Atin3umGzTBnPyXSV.webp',
  qualifier: 'https://d2xsxph8kpxj0f.cloudfront.net/310519663259840902/AXotyppPfFeghR67Uzfaab/offer801-courtyard-clean-KqDL6AqqXYREWP6gYVxE9T.webp',
  compare: 'https://d2xsxph8kpxj0f.cloudfront.net/310519663259840902/AXotyppPfFeghR67Uzfaab/offer801-green-life-clean-dUMd5Atin3umGzTBnPyXSV.webp',
  evolution: 'https://d2xsxph8kpxj0f.cloudfront.net/310519663259840902/AXotyppPfFeghR67Uzfaab/offer801-interior-clean-iWWvJJ96yaYAh4KrVnVRRa.webp',
  footer: 'https://d2xsxph8kpxj0f.cloudfront.net/310519663259840902/AXotyppPfFeghR67Uzfaab/offer801-strategy-clean-E5MfcWKwwZcEvkEZgCTEGq.webp',
  currentPositioning: '/assets/offer801/current_positioning.png',
};

const triggerPoints = [
  'Когда день начинается и заканчивается в шуме, плотности и постоянной нехватке воздуха.',
  'Когда маршрут ребёнка, дорога, двор и быт каждый день собираются через лишние компромиссы.',
  'Когда хочется жить ближе к природе и тишине, но без ощущения, что ты выпал из города и привычной логистики.',
  'Когда семье нужен не просто новый метраж, а более спокойная, безопасная и предсказуемая среда на каждый день.',
];

const responseCards = [
  {
    number: '01',
    title: 'Семье нужен двор, который не тревожит, а поддерживает жизнь',
    problem:
      'Когда ребёнку негде безопасно гулять, а любое движение за пределами квартиры требует лишнего контроля, даже хорошая планировка перестаёт спасать.',
    answer:
      'В «Дома у сада» ценность двора можно показывать не как украшение проекта, а как часть нормального семейного ритма — прогулки, воздух, визуальный покой, предсказуемая среда рядом с домом.',
    detail:
      'Это важный разворот: человек покупает не “двор с озеленением”, а ощущение, что повседневная жизнь ребёнка и взрослых становится легче организуемой.',
    cta: 'Показать, как эту ценность можно упаковать в оффер проекта',
    image: images.aha1,
    alt: 'Семейный двор как поддерживающая среда рядом с домом',
  },
  {
    number: '02',
    title: 'Квартира должна выдерживать рост семейного сценария, а не только текущий момент',
    problem:
      'Семьи редко ищут жильё только “на сейчас”. Их тревожит, насколько квартира выдержит следующий этап: больше вещей, больше бытовых задач, больше потребности в личном и общем пространстве.',
    answer:
      'Поэтому проект важно показывать как место, где семья не просто переезжает, а получает более жизнеспособную базу — свет, воздух, сценарии для общей жизни, ощущение собранности дома.',
    detail:
      'Даже если конкретный пользователь ещё не формулирует это словами, он покупает не метраж, а шанс не упереться в новую тесноту через короткий промежуток времени.',
    cta: 'Обсудить, как показать семейный рост без штампов про метры',
    image: images.aha2,
    alt: 'Светлый интерьер как база для семейной жизни на вырост',
  },
  {
    number: '03',
    title: 'Жить ближе к природе — не значит выпадать из городской жизни',
    problem:
      'Многие проекты обещают тишину, но на практике заставляют человека платить за неё логистическим разрывом, потерей времени и ощущением удалённости от нормальной жизни города.',
    answer:
      '«Дома у сада» стоит раскрывать через более зрелую формулу: природа и спокойствие здесь не противопоставлены связности, а собираются в баланс, который делает семейную жизнь устойчивее.',
    detail:
      'Это снимает один из главных внутренних конфликтов клиента: не выбирать между “городом” и “жизнью”, а получить более человеческий режим, не обнуляя удобство.',
    cta: 'Если в проекте есть сильная ценность, которую рынок пока не считывает — обсудим переупаковку',
    image: images.aha3,
    alt: 'Природная среда рядом с городом без ощущения удалённости',
  },
];

const selfSelection = [
  'Для тех, кто устал от перегруженного городского быта и хочет больше воздуха в ежедневной жизни.',
  'Для тех, кому важны двор, безопасность, природное окружение и спокойный ритм как часть нормальной семейной среды.',
  'Для тех, кто не хочет выбирать между близостью к городу и ощущением, что жить стало тише и легче.',
  'Для тех, кому нужна не просто квартира, а более собранный жизненный контур на несколько лет вперёд.',
];

const comparisons = [
  {
    overline: 'Против generic family-коммуникации',
    title: 'Не “семейный ЖК”, а семейная жизнь с меньшим трением',
    text: 'Сила проекта — не в абстрактных словах про заботу о семье, а в более спокойном, зелёном и лучше организованном режиме повседневной жизни.',
  },
  {
    overline: 'Против продажи только метража',
    title: 'Не квадратные метры, а жизненный переход семьи',
    text: 'Переезд здесь нужно упаковывать как смену жизненного контура: больше воздуха, меньше усталости, более понятный быт и среда, которая выдерживает следующий семейный цикл.',
  },
  {
    overline: 'Против ложного выбора между городом и природой',
    title: 'Связность без шумной плотности',
    text: 'Проект выигрывает там, где показывает возможность жить мягче и зеленее, не разрывая привычную логику города, семейных маршрутов и рабочего ритма.',
  },
];

const lifeStages = [
  {
    stage: 'Стадия 01 · текущая подача звучит слишком общей',
    price: 'CEO view',
    who: 'ЖК выглядит как ещё один “семейный проект”: аккуратно, но без точного ответа, почему именно эта аудитория должна выбрать его среди похожих предложений.',
    hire: 'Увидеть, где продукт сильнее своей текущей упаковки и какие смыслы сейчас теряются в слишком общих формулировках.',
    format: 'Диагностика разрыва между реальной ценностью проекта и тем, как он звучит на рынке.',
  },
  {
    stage: 'Стадия 02 · перейти от метража к жизненному переходу семьи',
    price: 'CEO view',
    who: 'Сильная сторона проекта не в словах про благоустройство сами по себе, а в возможности показать более спокойный, зелёный и собранный режим семейной жизни.',
    hire: 'Переформулировать оффер так, чтобы он продавал не характеристики, а новый сценарий повседневности для семьи второго цикла.',
    format: 'Сдвиг от описания объекта к описанию того job, который клиент реально нанимает проект решить.',
  },
  {
    stage: 'Стадия 03 · собрать разрозненные плюсы в одно позиционирование',
    price: 'CEO view',
    who: 'Двор, природа, связность с городом и семейный сценарий уже есть в продукте, но пока не собраны в одну внятную причину выбрать именно этот ЖК.',
    hire: 'Соединить продуктовые факты в единую narrative-рамку, которая считывается и в оффере, и на странице, и в разговоре отдела продаж.',
    format: 'Переход от набора сильных сторон к цельной architecture of value.',
  },
  {
    stage: 'Стадия 04 · перевести новую логику в оффер, страницу и встречу',
    price: 'CEO view',
    who: 'После диагностики важно не просто признать проблему, а зафиксировать следующий шаг: какую гипотезу переупаковки тестировать в лендинге, креативах и коммуникации.',
    hire: 'Получить конкретное направление для управленческого решения: доработать сегмент, изменить подачу или полностью пересобрать упаковку проекта.',
    format: 'B2B-часть лендинга: от понимания эволюции запроса к следующему шагу по переупаковке.',
  },
];

const processSteps = [
  {
    number: '01',
    title: 'Вы оставляете контакты и ссылку на проект',
    text: 'Показываете текущий ЖК, лендинг или рекламную коммуникацию, которая не даёт нужной конверсии.',
  },
  {
    number: '02',
    title: 'Мы собираем гипотезу переупаковки',
    text: 'Смотрим, как проект позиционируется сейчас, и находим, где сильные стороны ЖК остаются слишком общими или недосказанными.',
  },
  {
    number: '03',
    title: 'Проводим встречу по проекту',
    text: 'Затем собираем клиентский job и показываем, как можно пересобрать оффер, структуру страницы, визуальные акценты и аргументацию под желаемый переход клиента.',
  },
  {
    number: '04',
    title: 'Фиксируем следующий шаг',
    text: 'И уже после этого определяем, что делать дальше: корректировать сегмент, перепрошивать оффер или полностью пересобирать упаковку проекта.',
  },
];
---

<html lang="ru">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>Как переупаковать ЖК «Дома у сада» под реальный семейный job — пример для Ак Барс Дом</title>
    <meta
      name="description"
      content="Показываем, как можно раскрыть ценность ЖК «Дома у сада» не через общие обещания о семейном проекте, а через конкретный жизненный переход семьи к более спокойной, зелёной и собранной среде."
    />
  </head>
  <body class="landing-745">
    <Analytics landingSlug={slug} />

    <main>
      <section class="hero745 section section--photo-hero">
        <div class="hero745__backdrop" style={`--section-bg: url(${images.hero})`}></div>
        <div class="container hero745__container">
          <div class="hero745__label">Переупаковка ценности жилого проекта под реальный семейный job</div>
          <div class="hero745__grid">
            <div class="hero745__content hero745__content--glass">
              <h1>Как показать ЖК «Дома у сада» не как ещё одну семейную новостройку, а как понятный переход семьи в более спокойную, зелёную и собранную жизнь</h1>
              <p class="hero745__lead">
                У проекта уже есть сильная база: природное окружение, семейный сценарий, благоустройство, близость к Казани и ощущение квартала-среды.
                Но если всё это говорить слишком общо, часть реальной ценности остаётся нераспакованной. Мы предлагаем показать «Дома у сада»
                как готовое жизненное решение для семей, которые устали от городского шума, бытовой тесноты и постоянных компромиссов.
              </p>
              <p class="hero745__offer-line">Природная среда · дворы как сценарий жизни · формат проекта, в котором семье легче жить</p>
              <div class="hero745__actions hero745__actions--stacked">
                <a class="button745 button745--primary" href="#contact">Показать вариант переупаковки проекта</a>
              </div>
            </div>

            <aside class="hero745__card hero745__card--floating">
              <div class="hero745__card-body">
                <h2>Семейный проект, который можно переупаковать из разговора “о проекте” в разговор о человеке и его задаче</h2>
                <p class="hero745__meta">Природная среда · семейный сценарий · связность с городом</p>
                <p>
                  Сильнее всего «Дома у сада» звучит тогда, когда говорит не о наборе преимуществ, а о переходе семьи
                  в среду, где каждый день становится спокойнее, легче и лучше собран.
                </p>
              </div>
            </aside>
          </div>
        </div>
      </section>

      <section class="section section--tight triggers745-wrap triggers745-wrap--hero-continued">
        <div class="hero745__backdrop hero745__backdrop--continued" style={`--section-bg: url(${images.hero})`}></div>
        <div class="triggers745__tone"></div>
        <div class="container triggers745__container">
          <div class="triggers745">
            {triggerPoints.map((item) => <p>{item}</p>)}
          </div>
        </div>
      </section>

      <section class="immersive745 immersive745--hero" style={`--immersive-bg: url(${images.aha1})`}>
        <div class="container immersive745__inner">
          <div class="immersive745__card">
            <p class="immersive745__eyebrow">ЖК «Дома у сада» · готовое семейное решение</p>
            <h2>«Дома у сада» можно показать как уже собранное семейное решение, а не как набор разрозненных преимуществ</h2>
            <p>
              Сила проекта не в одной отдельной характеристике, а в том, как среда складывается в целостный сценарий:
              зелёное окружение, дворы, безопасность, понятные маршруты, ощущение воздуха и более мягкий ритм повседневности.
            </p>
            <div class="immersive745__facts">
              <span>Природная среда, которая не отрывает семью от города</span>
              <span>Дворы и благоустройство как часть ежедневного жизненного сценария</span>
              <span>Формат проекта, в котором семье легче дышать и жить в своём ритме</span>
              <span>Позиционирование, которое можно переупаковать под реальный клиентский job</span>
            </div>
          </div>
        </div>
      </section>

      <section class="section responses745 section--photo-soft" style={`--section-bg: url(${images.aha2})`}>
        <div class="responses745__veil"></div>
        <div class="container responses745__container">
          <div class="section745-heading center745 section745-heading--light">
            <h2>Как «Дома у сада» отвечает на то, что по-настоящему ищет семья второго цикла</h2>
          </div>
          <div class="responses745__stack">
            {responseCards.map((card) => (
              <article class="response745-card">
                <div class="response745-card__media">
                  <img src={card.image} alt={card.alt} loading="lazy" />
                </div>
                <div class="response745-card__body">
                  <div class="response745-card__number">{card.number}</div>
                  <h3>{card.title}</h3>
                  <p class="response745-card__problem">{card.problem}</p>
                  <p>{card.answer}</p>
                  <p class="response745-card__detail">{card.detail}</p>
                  {card.cta && (
                    <a class="inline-link745" href="#contact">{card.cta}</a>
                  )}
                </div>
              </article>
            ))}
          </div>
        </div>
      </section>

      <section class="split-photo745">
        <div class="split-photo745__image" style={`--split-bg: url(${images.qualifier})`}></div>
        <div class="split-photo745__content-wrap">
          <div class="container split-photo745__container">
            <div class="split-photo745__content">
              <p class="immersive745__eyebrow">ЖК «Дома у сада» · самоотбор сегмента</p>
              <h2>Этот проект особенно силён для семей, которые ищут не статусный шум, а более устойчивую среду для жизни</h2>
              <div class="self745 self745--transparent">
                {selfSelection.map((item) => <p>{item}</p>)}
              </div>
              <blockquote class="quote745 quote745--light">
                <p>
                  «Сильные семейные проекты продаются не через обещания “счастливой жизни”, а через более точное ощущение,
                  что ежедневная жизнь семьи действительно становится тише, мягче и лучше собрана».
                </p>
                <footer>Стратегия переупаковки девелоперского продукта</footer>
              </blockquote>
              <a class="inline-link745 inline-link745--light" href="#contact">Если ваш продукт сильнее, чем его текущая упаковка — обсудим это на встрече</a>
            </div>
          </div>
        </div>
      </section>

      <section class="immersive745 immersive745--contrast" style={`--immersive-bg: url(${images.aha3})`}>
        <div class="container immersive745__inner immersive745__inner--right">
          <div class="immersive745__card immersive745__card--single-story">
            <div class="story745-card">
              <div class="story745-card__number">03</div>
              <h2>Проблема не обязательно в самом продукте. Часто она в том, что сильный проект описывается слишком общо и теряет собственный жизненный смысл.</h2>
              <p class="story745-card__problem">Если показывать «Дома у сада» просто как современный семейный жилой комплекс с благоустройством и хорошей локацией, коммуникация остаётся в категории привычных рыночных обещаний.</p>
              <p>Но если раскрыть проект через реальный job семьи — усталость от шума, потребность в более мягком повседневном ритме, поиск среды, а не только квартиры — ценность становится гораздо конкретнее и сильнее.</p>
              <a class="inline-link745" href="#contact">Если у вашего проекта есть ценность, которую рынок пока не считывает — давайте это разберём</a>
            </div>
          </div>
        </div>
      </section>

      <section class="section life745 section--photo-soft" style={`--section-bg: url(${images.evolution})`}>
        <div class="responses745__veil responses745__veil--warm"></div>
        <div class="container life745__container">
          <div class="section745-heading center745 section745-heading--light section745-heading--max">
            <h2>Именно здесь начинается переупаковка: от продажи объекта — к артикуляции жизненного перехода, который человек действительно хочет совершить</h2>
            <p>Эта таблица показывает, как проект становится сильнее, когда говорит не про характеристики объекта, а про переход, который семья действительно хочет совершить.</p>
          </div>
          <div class="life745-table-wrap">
            <table class="life745-table">
              <thead>
                <tr>
                  <th>Уровень</th>
                  <th>Что происходит с семьёй</th>
                  <th>Что она на самом деле ищет</th>
                  <th>Как это упаковывать</th>
                </tr>
              </thead>
              <tbody>
                {lifeStages.map((item) => (
                  <tr>
                    <td>
                      <strong>{item.stage}</strong>
                      <span>{item.price}</span>
                    </td>
                    <td>{item.who}</td>
                    <td>{item.hire}</td>
                    <td>{item.format}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
          <div class="center745 action745-wrap">
            <a class="button745 button745--ghost" href="#contact">Обсудить, как упаковать ЖК под реальный семейный job</a>
          </div>
        </div>
      </section>

      <section class="section compare745 section--contrast">
        <div class="compare745__backdrop" style={`--compare-bg: url(${images.compare})`}></div>
        <div class="container compare745__container">
