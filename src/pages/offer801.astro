---
import Analytics from '../components/Analytics.astro';
import '../styles/global.css';

const slug = 'offer801';
const formName = 'offer801-repack-request';

const images = {
  hero: 'https://d2xsxph8kpxj0f.cloudfront.net/310519663259840902/AXotyppPfFeghR67Uzfaab/offer801-hero-clean-Lqy3vDEe5JDxTYL6dn5xSm.webp',
  aha1: 'https://d2xsxph8kpxj0f.cloudfront.net/310519663259840902/AXotyppPfFeghR67Uzfaab/offer801-courtyard-clean-KqDL6AqqXYREWP6gYVxE9T.webp',
  aha2: 'https://d2xsxph8kpxj0f.cloudfront.net/310519663259840902/AXotyppPfFeghR67Uzfaab/offer801-interior-clean-iWWvJJ96yaYAh4KrVnVRRa.webp',
  aha3: 'https://d2xsxph8kpxj0f.cloudfront.net/310519663259840902/AXotyppPfFeghR67Uzfaab/offer801-green-life-clean-dUMd5Atin3umGzTBnPyXSV.webp',
  qualifier: 'https://d2xsxph8kpxj0f.cloudfront.net/310519663259840902/AXotyppPfFeghR67Uzfaab/offer801-courtyard-clean-KqDL6AqqXYREWP6gYVxE9T.webp',
  compare: 'https://d2xsxph8kpxj0f.cloudfront.net/310519663259840902/AXotyppPfFeghR67Uzfaab/offer801-green-life-clean-dUMd5Atin3umGzTBnPyXSV.webp',
  evolution: 'https://d2xsxph8kpxj0f.cloudfront.net/310519663259840902/AXotyppPfFeghR67Uzfaab/offer801-interior-clean-iWWvJJ96yaYAh4KrVnVRRa.webp',
  footer: 'https://d2xsxph8kpxj0f.cloudfront.net/310519663259840902/AXotyppPfFeghR67Uzfaab/offer801-strategy-clean-E5MfcWKwwZcEvkEZgCTEGq.webp',
  currentPositioning: '/assets/offer801/current_positioning_user.webp',
};

const triggerPoints = [
  'У каждого всё меньше своего места. Даже если квартира формально «нормальная», в ней всё чаще не хватает не метров, а границ: детям, взрослым, тишине, работе и отдыху.',
  'Дом всё ещё временный, хотя жизнь уже давно нет. Пространство продолжает ощущаться как промежуточное решение, хотя маршруты, школа, ритм семьи и сам образ жизни давно стали постоянными.',
  'Слишком много быта держится на постоянной подстройке. Когда дом не поддерживает уклад, семье приходится всё время договариваться, делить, терпеть и компенсировать.',
  'В какой-то момент становится ясно: дело не в том, чтобы «улучшить условия», а в том, чтобы перестать жить ниже собственного этапа жизни.',
];

const responseCards = [
  {
    number: '01',
    title: 'У каждого появляется своё место',
    problem:
      'Это не просто больше пространства, а меньше трения в повседневной жизни: детям легче расти, взрослым легче сохранять границы, семье легче быть вместе без постоянной тесноты.',
    answer:
      'В «Дома у сада» это можно раскрывать через приватные сценарии, воздух, спокойный ритм и пространство, которое помогает быту, а не усложняет его.',
    detail:
      'Тогда проект читается не как формальный семейный ЖК, а как дом, в котором семье действительно становится легче жить на следующем этапе.',
    cta: '',
    image: images.aha1,
    alt: 'У каждого появляется своё место в зрелом семейном сценарии',
  },
  {
    number: '02',
    title: 'Жизнь остаётся в своём районе, но становится качественно другой',
    problem:
      'Можно не ломать уже сложившуюся экосистему семьи: привычные маршруты, школу, близких, секции, ритм района и всё то, что уже стало частью жизни.',
    answer:
      'Поэтому «Дома у сада» важно показывать не как отрыв от привычного уклада, а как более зрелую версию того же жизненного контура — спокойнее, мягче и собраннее.',
    detail:
      'Так проект снимает страх переезда как разрушения привычной жизни и превращается в естественный следующий шаг семьи.',
    cta: '',
    image: images.aha2,
    alt: 'Семейная жизнь сохраняет районную связность, но становится качественно другой',
  },
  {
    number: '03',
    title: 'Дом выдерживает длинный горизонт',
    problem:
      'Это не временная развилка и не компромисс на пару лет, а пространство, которое может поддерживать семью долго и без быстрого морального устаревания.',
    answer:
      'Именно так «Дома у сада» может читаться как выбор не ради самого переезда, а ради более спокойной, логичной и устойчивой жизни семьи на годы вперёд.',
    detail:
      'Особенно важно, чтобы переезд не просто менял адрес, а действительно переводил жизнь на более зрелый уровень.',
    cta: '',
    image: images.aha3,
    alt: 'Дом как долгосрочная база для зрелой семьи',
  },
];

const selfSelection = [
  '«Дома у сада» имеет смысл переупаковывать именно для тех, кто не ищет срочный апгрейд ради галочки и не выбирает жильё как демонстрацию статуса.',
  'Это выбор для семей, которым важно, чтобы у каждого было своё место, чтобы привычная жизнь не разрушалась переездом и чтобы новый дом действительно выдерживал длинный горизонт.',
  'Если семья больше не хочет жить по инерции, а хочет жить в соответствии с тем, кем она стала, этот сегмент узнаёт себя почти сразу.',
  'Не «ещё одна квартира для семьи», а более зрелая база для следующего этапа жизни.',
  '«Не “ещё одна квартира для семьи”, а более зрелая база для следующего этапа жизни».',
];

const comparisons = [];

const lifeStages = [
  {
    stage: 'Стадия 01 · сначала семье важно просто иметь своё',
    price: 'JTBD / B2B view',
    who: 'На первом цикле жильё решает базовую задачу закрепления: своё пространство, понятная опора и старт семейной жизни.',
    hire: 'На этом этапе семья выбирает не зрелый сценарий, а факт собственного дома как основы нового этапа.',
    format: 'Для девелопера это базовый рынок семейного жилья, где ещё работает общий язык про метры, планировки и понятный комфорт.',
  },
  {
    stage: 'Стадия 02 · потом жизнь семьи становится сложнее и устойчивее',
    price: 'JTBD / B2B view',
    who: 'Появляются дети, школа, секции, маршруты, связи с районом и более сложная организация повседневности.',
    hire: 'С этого момента выбор жилья перестаёт быть только квартирным и становится жизненно-логистическим.',
    format: 'Именно здесь сегмент начинает отличаться от общей аудитории семей с детьми и требует более точного позиционирования.',
  },
  {
    stage: 'Стадия 03 · пространство перестаёт соответствовать этой жизни',
    price: 'JTBD / B2B view',
    who: 'Дом начинает требовать от семьи слишком много компенсации: подстройки, терпения, логистических и бытовых компромиссов.',
    hire: 'На языке продукта это означает: текущая упаковка должна продавать не улучшение условий вообще, а снятие накопленного трения зрелой семьи.',
    format: 'Именно здесь открывается настоящий JTBD-сегмент, а не просто широкая категория семейной аудитории.',
  },
  {
    stage: 'Стадия 04 · выбор смещается с метров на способ жизни',
    price: 'JTBD / B2B view',
    who: 'Семья начинает выбирать не просто квартиру побольше, а пространство, которое способно поддерживать её уклад на долгий срок.',
    hire: 'Здесь офферу уже недостаточно говорить языком метража: он должен собирать более зрелый жизненный переход.',
    format: 'Для CEO это точка, где продукт нужно переупаковывать вокруг новой семейной задачи, а не вокруг набора характеристик.',
  },
  {
    stage: 'Стадия 05 · дом становится не сделкой, а долгосрочной базой',
    price: 'JTBD / B2B view',
    who: 'Именно здесь продукт можно переупаковать точнее: как физическую и психологическую опору зрелой семьи.',
    hire: 'Этот сдвиг и превращает «семьи с детьми» в отдельный, более глубокий JTBD-сегмент.',
    format: 'Дальше задача девелопера — перевести эту логику в оффер, страницу, креативы и аргументацию отдела продаж.',
  },
];

const processSteps = [
  {
    number: '01',
    title: 'Вы оставляете контакты и ссылку на проект',
    text: 'Показываете текущий ЖК, лендинг или рекламную коммуникацию, которая не даёт нужной конверсии.',
  },
  {
    number: '02',
    title: 'Мы собираем гипотезу переупаковки',
    text: 'Смотрим, как проект позиционируется сейчас, и находим, где сильные стороны ЖК остаются слишком общими или недосказанными.',
  },
  {
    number: '03',
    title: 'Проводим встречу по проекту',
        text: 'Показываем, как можно пересобрать оффер, структуру страницы, визуальные акценты и аргументацию под зрелый семейный сегмент.',
  },
  {
    number: '04',
    title: 'Фиксируем следующий шаг',
    text: 'После этого определяем, что делать дальше: корректировать сегмент, перепрошивать оффер или полностью пересобирать упаковку проекта.',
  },
];
---

<html lang="ru">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>ЖК «Дома у сада» — для семьи, которая уже выросла из прежнего формата жизни</title>
    <meta
      name="description"
      content="Показываем, как ЖК «Дома у сада» можно раскрыть как зрелый семейный сценарий: с местом для каждого, спокойным ритмом и ощущением дома надолго."
    />
  </head>
  <body class="landing-745">
    <Analytics landingSlug={slug} />

    <main>
      <section class="hero745 section section--photo-hero">
        <div class="hero745__backdrop" style={`--section-bg: url(${images.hero})`}></div>
        <div class="container hero745__container">
          <div class="hero745__label">Казанская агломерация · зрелый семейный сценарий</div>
          <div class="hero745__grid">
            <div class="hero745__content hero745__content--glass">
              <h1>Если семья выросла, дом тоже должен вырасти вместе с ней</h1>
              <p class="hero745__lead">
                Когда жизнь семьи стала сложнее, глубже и устойчивее, пространство тоже должно начать ей соответствовать: с местом для каждого,
                спокойным ритмом и ощущением, что это дом не на время, а надолго.
              </p>
              <p class="hero745__offer-line">Природное окружение · семейный двор · планировки, которые выдерживают следующий этап жизни</p>
              <div class="hero745__actions hero745__actions--stacked">
                <a class="button745 button745--primary" href="#contact">запросить консультацию</a>
              </div>
            </div>

            <aside class="hero745__card hero745__card--floating">
              <div class="hero745__card-body">
                <h2>«Дома у сада» — жилой сценарий для тех, кто не хочет ещё 10–15 лет жить в компромиссе между теснотой, привычкой и инерцией</h2>
                <p class="hero745__meta">Природное окружение · семейный двор · планировки, которые выдерживают следующий этап жизни</p>
                <p>
                  Этот проект можно показывать не как ещё один общий семейный ЖК, а как пространство, которое начинает соответствовать
                  реальному уровню семьи и поддерживать её повседневную жизнь без лишнего трения.
                </p>
              </div>
            </aside>
          </div>
        </div>
      </section>

      <section class="section section--tight triggers745-wrap triggers745-wrap--hero-continued">
        <div class="hero745__backdrop hero745__backdrop--continued" style={`--section-bg: url(${images.hero})`}></div>
        <div class="triggers745__tone"></div>
        <div class="container triggers745__container">
          <div class="section745-heading center745 section745-heading--light section745-heading--max triggers745__heading">
            <h2>Иногда проблема не в том, что квартиры мало. А в том, что семья уже стала больше этого сценария.</h2>
          </div>
          <div class="triggers745">
            {triggerPoints.map((item) => <p>{item}</p>)}
          </div>
        </div>
      </section>

      <section class="immersive745 immersive745--hero" style={`--immersive-bg: url(${images.aha1})`}>
        <div class="container immersive745__inner">
          <div class="immersive745__card">
              <p class="immersive745__eyebrow">ЖК «Дома у сада» · зрелый семейный сценарий</p>
              <h2>«Дома у сада» можно подать не как «ещё один семейный ЖК», а как дом, в котором семье больше не нужно бороться с бытом</h2>
              <p class="immersive745__body immersive745__body--light">
                Если посмотреть на «Дома у сада» не через общий рынок, а через задачу зрелой семьи, в нём можно увидеть
                не просто квадратные метры, а более зрелую организацию повседневной жизни.
              </p>
              <p class="immersive745__body immersive745__body--light">
                Здесь ценность создают не абстрактные преимущества, а конкретные условия, которые снимают накопившееся напряжение:
                природное окружение, семейный двор, связность с Казанью и планировки, поддерживающие более спокойный ритм жизни.
              </p>
              <p class="immersive745__body immersive745__body--light">
                Поэтому «Дома у сада» может читаться как выбор не ради переезда самого по себе, а ради более спокойной, логичной и устойчивой жизни семьи на годы вперёд.
              </p>
              <div class="immersive745__facts">
                <span>Природное окружение и тишина как часть нормального семейного режима</span>
                <span>Дворы, где ребёнок и взрослые получают больше спокойствия и предсказуемости</span>
                <span>Связность с городом без ощущения, что семья выпадает из привычной жизни</span>
                <span>Формат проекта, который можно читать как дом надолго, а не как временный апгрейд</span>
              </div>
              <p class="immersive745__bridge immersive745__bridge--light">Это и есть главный поворот: семья покупает не просто новую квартиру, а более правильную организацию собственной жизни.</p>
          </div>
        </div>
      </section>

      <section class="section responses745 section--photo-soft" style={`--section-bg: url(${images.aha2})`}>
        <div class="responses745__veil"></div>
        <div class="container responses745__container">
          <div class="section745-heading center745 section745-heading--light">
            <h2>Три причины, почему зрелая семья может узнать себя в этом проекте</h2>
          </div>
          <div class="responses745__stack">
            {responseCards.map((card) => (
              <article class="response745-card">
                <div class="response745-card__media">
                  <img src={card.image} alt={card.alt} loading="lazy" />
                </div>
                <div class="response745-card__body">
                  <div class="response745-card__number">{card.number}</div>
                  <h3>{card.title}</h3>
                  <p class="response745-card__problem">{card.problem}</p>
                  <p>{card.answer}</p>
                  <p class="response745-card__detail">{card.detail}</p>
                  {card.cta && (
                    <a class="inline-link745" href="#contact">{card.cta}</a>
                  )}
                </div>
              </article>
            ))}
          </div>
        </div>
      </section>

      <section class="split-photo745">
        <div class="split-photo745__image" style={`--split-bg: url(${images.qualifier})`}></div>
        <div class="split-photo745__content-wrap">
          <div class="container split-photo745__container">
            <div class="split-photo745__content">
              <p class="immersive745__eyebrow">ЖК «Дома у сада» · самоотбор зрелой семьи</p>
              <h2>Этот сценарий узнают не все семьи — а те, кто уже вырос из жизни «как получается»</h2>
              <div class="self745 self745--transparent self745--light">
                {selfSelection.map((item) => <p>{item}</p>)}
              </div>
              <blockquote class="quote745 quote745--light">
                <p>
                  «Не “ещё одна квартира для семьи”, а более зрелая база для следующего этапа жизни».
                </p>
                <footer>Зрелый семейный сегмент</footer>
              </blockquote>
            </div>
          </div>
        </div>
      </section>

      <section class="immersive745 immersive745--contrast" style={`--immersive-bg: url(${images.aha3})`}>
        <div class="container immersive745__inner immersive745__inner--right">
          <div class="immersive745__card immersive745__card--single-story">
              <div class="story745-card story745-card--light-copy">
              <div class="story745-card__number">05</div>
              <h2>Переезд должен не просто изменить адрес, а действительно перевести жизнь семьи на более зрелый уровень.</h2>
              <p class="story745-card__problem">Именно здесь девелопер может перейти от общей категории семейного жилья к более точному позиционированию, которое совпадает с реальным следующим этапом жизни семьи.</p>
              <a class="inline-link745 inline-link745--light" href="#contact">Посмотреть, как этот переход собирается в сегментную логику и новую подачу</a>
            </div>
          </div>
        </div>
      </section>



      <section class="section compare745 section--contrast">
        <div class="compare745__backdrop" style={`--compare-bg: url(${images.compare})`}></div>
        <div class="container compare745__container">
          <div class="section745-heading section745-heading--light section745-heading--max">
            <p class="section745-heading__eyebrow">Как этот сегмент превращается в управленческое решение</p>
            <h2>Как общий язык про семейный ЖК можно превратить в точное попадание в зрелый сегмент</h2>
          </div>
          <div class="compare745__grid">
            {comparisons.map((item) => (
              <article class="compare745-card">
                <p class="compare745-card__eyebrow">{item.overline}</p>
                <h3>{item.title}</h3>
                <p>{item.text}</p>
              </article>
            ))}
          </div>
        </div>
      </section>

      <section class="section process745 section--photo-band" style={`--section-bg: url(${images.footer})`}>
        <div class="section-band745__overlay section-band745__overlay--dark"></div>
        <div class="container process745__container">
          <div class="section745-heading center745 section745-heading--light section745-heading--max">
            <h2>Как превратить общий язык про семейный ЖК в точное попадание в зрелый сегмент</h2>
            <p>Если текущее позиционирование не приводит к продажам, оставьте контакты в форме, проведем встречу и расскажем о своем подходе</p>
          </div>
          <div class="process745__grid process745__grid--stacked">
            {processSteps.map((step) => (
              <article class="process745-card process745-card--light process745-card--stacked">
                <div class="process745-card__number">{step.number}</div>
                <h3>{step.title}</h3>
                <p>{step.text}</p>
              </article>
            ))}
          </div>
        </div>
      </section>

      <section id="contact" class="section final745 final745--photo">
        <div class="final745__backdrop" style={`--final-bg: url(${images.footer})`}></div>
        <div class="container final745__container">
          <div class="final745__layout">
            <div class="final745__media-copy">
              <p class="final745__eyebrow">Текущий пример позиционирования проекта</p>
              <h2>Покажем, как может выглядеть переупаковка ЖК «Дома у сада» под зрелый семейный сегмент</h2>

              <div class="final745__positioning-shot">
