---
import Analytics from '../components/Analytics.astro';
import '../styles/global.css';

const slug = 'offer801';
const formName = 'offer801-repack-request';

const images = {
  hero: '/assets/offer801/ak-bars-dom_doma-u-sada_hero.webp',
  aha1: '/assets/offer801/ak-bars-dom_doma-u-sada_hero.webp',
  aha2: '/assets/offer801/ak-bars-dom_doma-u-sada_hero.webp',
  aha3: '/assets/offer801/ak-bars-dom_doma-u-sada_hero.webp',
  qualifier: '/assets/offer801/ak-bars-dom_doma-u-sada_hero.webp',
  compare: '/assets/offer801/ak-bars-dom_doma-u-sada_hero.webp',
  evolution: '/assets/offer801/ak-bars-dom_doma-u-sada_hero.webp',
  footer: '/assets/offer801/ak-bars-dom_doma-u-sada_hero.webp',
  currentPositioning: '/assets/offer801/current_positioning.webp',
};

const triggerPoints = [
  'Вы переросли квартиру, в которой семья всё время сталкивается друг с другом вместо того, чтобы жить в нормальном ритме.',
  'Вы хотите, чтобы у ребёнка были воздух, двор и предсказуемая среда рядом с домом, а не только ещё один адрес в плотной городской застройке.',
  'Вы ищете место, где можно жить спокойнее и зеленее, но не готовы платить за это выпадением из привычной городской логистики.',
];

const responseCards = [
  {
    number: '01',
    title: 'Двор как продолжение квартиры',
    problem: '«Нам уже мало просто новой планировки. Нужна среда, где ребёнка не приходится постоянно выдёргивать из опасного или случайного окружения».',
    answer:
      'В “Дома у сада” двор можно показывать не как стандартное благоустройство для буклета, а как часть семейного уклада: пространство, где ребёнок гуляет в более понятной и спокойной среде, а взрослые не живут в режиме постоянного контроля.',
    detail:
      'Тогда проект начинает продаваться не обещанием “двор без машин”, а более глубоким ощущением — семье становится легче организовывать повседневную жизнь рядом с домом.',
    cta: 'Посмотреть, как эта логика может работать в позиционировании проекта',
    image: images.aha1,
    alt: 'Жилой квартал с зелёным двором и семейной средой',
  },
  {
    number: '02',
    title: 'Жизнь на вырост, а не только на сейчас',
    problem: '«Мы не хотим переезжать просто ради дополнительного метража и через два года снова оказаться в тесноте и усталости».',
    answer:
      'Сила проекта раскрывается в том, что он обещает семье не короткий бытовой апгрейд, а более устойчивую базу на несколько лет вперёд: больше воздуха, лучше организованный быт, больше сценариев для общей и личной жизни.',
    detail:
      'Здесь важно продавать не квадратные метры сами по себе, а возможность перестать всё время подстраивать жизнь под ограничения старого контура.',
    cta: 'Обсудить, как показать семейный рост без банальных слов про простор',
    image: images.aha2,
    alt: 'Современная семейная квартира со светом и ощущением воздуха',
  },
  {
    number: '03',
    title: 'Природа без ощущения, что вы уехали из жизни',
    problem: '«Нам нужна тишина и зелень, но не хочется платить за это ощущением удалённости, сложной логистикой и потерей городского темпа».',
    answer:
      '“Дома у сада” можно раскрывать через зрелый баланс: проект не противопоставляет природную среду городской жизни, а собирает их в более человеческий режим, где семье легче дышать, но не приходится выпадать из привычных маршрутов.',
    detail:
      'Это снимает один из главных внутренних конфликтов семейного выбора: не выбирать между “удобно” и “по-человечески”, а получить обе ценности сразу в одном сценарии.',
    cta: 'Если в проекте есть сильная ценность, которую рынок не считывает, — обсудим переупаковку',
    image: images.aha3,
    alt: 'Семейный жилой проект рядом с природой и городской связностью',
  },
];

const selfSelection = [
  'Для семей, которые уже чувствуют, что прежний формат жизни стал тесным не только по метражу, но и по самому качеству повседневности.',
  'Для тех, кому важны двор, воздух, безопасная среда и более мягкий ритм дня — без потери связи с городом.',
  'Для родителей, которые выбирают не просто квартиру побольше, а более устойчивую среду, в которой ребёнок и взрослые живут спокойнее.',
  'Для тех, кто хочет, чтобы следующий переезд был не временным компромиссом, а более точным жизненным решением на годы вперёд.',
];

const comparisons = [
  {
    overline: 'Против generic family-коммуникации',
    title: 'Не “семейный ЖК”, а среда с меньшим повседневным трением',
    text: 'Проект выигрывает не там, где обещает абстрактный комфорт для семьи, а там, где показывает более спокойный, зелёный и лучше организованный режим ежедневной жизни.',
  },
  {
    overline: 'Против покупки только метража',
    title: 'Не квадратные метры, а жизненный переход семьи',
    text: 'Переезд здесь нужно упаковывать как смену жизненного контура: больше воздуха, лучше выстроенный быт, меньше усталости и больше устойчивости.',
  },
  {
    overline: 'Против ложного выбора между городом и природой',
    title: 'Связность без шумной плотности',
    text: 'Сильная сторона проекта — возможность жить мягче и зеленее, не разрывая привычную логику города и семейных маршрутов.',
  },
];

const lifeStages = [
  {
    stage: 'Устали от тесноты',
    price: 'JTBD stage 01',
    who: 'Семья чувствует, что старая квартира больше не выдерживает новый объём жизни: вещей, маршрутов, детских задач и усталости взрослых.',
    hire: 'Не просто больше метров, а ощущение, что дышать, собираться и жить стало легче.',
    format: 'Переход от бытовой перегрузки к более устойчивой семейной базе.',
  },
  {
    stage: 'Нужен нормальный двор',
    price: 'JTBD stage 02',
    who: 'Родители начинают искать не квартиру отдельно, а среду, в которой ребёнок растёт безопаснее, а день семьи проходит с меньшим напряжением.',
    hire: 'Более предсказуемый повседневный сценарий рядом с домом.',
    format: 'Проект как среда, а не просто жилой объект.',
  },
  {
    stage: 'Хотим жить спокойнее',
    price: 'JTBD stage 03',
    who: 'Семья уже не хочет шумной плотности, но и не готова к жизни, которая ощущается как отъезд из города и потеря связности.',
    hire: 'Баланс тишины, природы и обычной городской жизни.',
    format: 'Более человеческий режим дня без логистического разрыва.',
  },
  {
    stage: 'Выбираем на годы вперёд',
    price: 'JTBD stage 04',
    who: 'Покупка рассматривается как следующий семейный этап, который должен выдержать рост ребёнка, привычек и бытовых сценариев.',
    hire: 'Среду, которая не устареет через один жизненный цикл.',
    format: 'Квартира и проект как решение на вырост, а не временный компромисс.',
  },
];

const processSteps = [
  {
    number: '01',
    title: 'Вы оставляете контакты и ссылку на проект',
    text: 'Показываете текущий ЖК, лендинг или рекламную коммуникацию, которая не даёт нужной конверсии.',
  },
  {
    number: '02',
    title: 'Мы собираем гипотезу переупаковки',
    text: 'Смотрим сегмент, JTBD-напряжение, текущий оффер и архитектуру страницы, чтобы найти, где именно теряется сила проекта.',
  },
  {
    number: '03',
    title: 'Проводим встречу по проекту',
    text: 'Показываем, как может выглядеть более точное позиционирование, структура лендинга и конверсионная логика без банальных штампов.',
  },
  {
    number: '04',
    title: 'Фиксируем следующий шаг',
    text: 'Определяем, что именно нужно делать дальше: корректировать сегмент, перепрошивать оффер или полностью пересобирать упаковку проекта.',
  },
];
---

<html lang="ru">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>ЖК «Дома у сада» — более спокойная и зелёная семейная жизнь без выпадения из города</title>
    <meta
      name="description"
      content="Как показать ЖК «Дома у сада» не как ещё один семейный проект, а как понятный переход семьи в более спокойную, зелёную и устойчивую повседневную жизнь."
    />
  </head>
  <body class="landing-745">
    <Analytics landingSlug={slug} />

    <main>
      <section class="hero745 section section--photo-hero">
        <div class="hero745__backdrop" style={`--section-bg: url(${images.hero})`}></div>
        <div class="container hero745__container">
          <div class="hero745__label">Ак Барс Дом · ЖК «Дома у сада» · семья второго цикла</div>
          <div class="hero745__grid">
            <div class="hero745__content hero745__content--glass">
              <h1>Дом для семьи, которая уже переросла просто новую квартиру — <em>и теперь выбирает более спокойную, зелёную и собранную жизнь без выпадения из города.</em></h1>
              <p class="hero745__lead">
                «Дома у сада» — это проект для семей, которым стало тесно не только в старом метраже, но и в самом качестве повседневной жизни.
                Здесь ценность не в абстрактной “семейности”, а в более мягком ритме дня, понятном дворе, природном окружении и ощущении,
                что переезд действительно собирает жизнь заново — а не просто добавляет квадратные метры.
              </p>
              <p class="hero745__offer-line">Семейная среда · природное окружение · связность с городом</p>
              <div class="hero745__actions hero745__actions--stacked">
                <a class="button745 button745--primary" href="#contact">Показать вариант переупаковки проекта</a>
              </div>
            </div>

            <aside class="hero745__card hero745__card--floating">
              <div class="hero745__card-body">
                <h2>Семейный проект, который можно продавать не через шумные обещания, а через более устойчивый жизненный сценарий</h2>
                <p class="hero745__meta">Двор · Воздух · Баланс природы и города</p>
                <p>
                  Сильнее всего проект звучит тогда, когда говорит не о наборе преимуществ, а о переходе семьи в среду,
                  где каждый день становится чуть спокойнее, легче и лучше собран.
                </p>
              </div>
            </aside>
          </div>
        </div>
      </section>

      <section class="section section--tight triggers745-wrap triggers745-wrap--hero-continued">
        <div class="hero745__backdrop hero745__backdrop--continued" style={`--section-bg: url(${images.hero})`}></div>
        <div class="triggers745__tone"></div>
        <div class="container triggers745__container">
          <div class="triggers745">
            {triggerPoints.map((item) => <p>{item}</p>)}
          </div>
        </div>
      </section>

      <section class="immersive745 immersive745--hero" style={`--immersive-bg: url(${images.aha1})`}>
        <div class="container immersive745__inner">
          <div class="immersive745__card">
            <p class="immersive745__eyebrow">ЖК «Дома у сада» · жизненное решение для семьи</p>
            <h2>Когда проект перестаёт продаваться как “ещё один семейный ЖК” и начинает собираться вокруг подлинной задачи семьи</h2>
            <p>
              В этом кейсе важно не просто перечислять благоустройство, зелень и планировки. Важно показать, что “Дома у сада”
              отвечает на более глубокий запрос: помочь семье выйти из режима тесноты, шума и постоянного бытового трения
              в более устойчивую и человечную среду повседневной жизни.
            </p>
            <div class="immersive745__facts">
              <span>Семейный сценарий</span>
              <span>Природное окружение</span>
              <span>Понятный двор</span>
              <span>Связность без перегрузки</span>
            </div>
          </div>
        </div>
      </section>

      <section class="section responses745 section--photo-soft" style={`--section-bg: url(${images.aha2})`}>
        <div class="responses745__veil"></div>
        <div class="container responses745__container">
          <div class="section745-heading center745 section745-heading--light">
            <h2>Как «Дома у сада» отвечает на реальные напряжения семейного выбора</h2>
          </div>
          <div class="responses745__stack">
            {responseCards.map((card) => (
              <article class="response745-card">
                <div class="response745-card__media">
                  <img src={card.image} alt={card.alt} loading="lazy" />
                </div>
                <div class="response745-card__body">
                  <span class="response745-card__number">{card.number}</span>
                  <h3>{card.title}</h3>
                  <p class="response745-card__problem">{card.problem}</p>
                  <p>{card.answer}</p>
                  <p class="response745-card__detail">{card.detail}</p>
                  <a class="text-link745" href="#contact">{card.cta}</a>
                </div>
              </article>
            ))}
          </div>
        </div>
      </section>

      <section class="split-photo745 section">
        <div class="container split-photo745__grid">
          <div class="split-photo745__image-wrap">
            <img src={images.qualifier} alt="ЖК Дома у сада — спокойная семейная среда" loading="lazy" />
          </div>
          <div class="split-photo745__content">
            <div class="section745-heading">
              <h2>Этот проект особенно откликается семьям, которые ищут не статусный шум, а более устойчивую среду для жизни</h2>
            </div>
            <div class="split-photo745__list">
              {selfSelection.map((item) => (
                <div class="split-photo745__item">
                  <span>—</span>
                  <p>{item}</p>
                </div>
              ))}
            </div>
          </div>
        </div>
      </section>

      <section class="life745 section section--warm">
        <div class="container">
          <div class="section745-heading center745">
            <p class="section745-heading__eyebrow">От объекта — к жизненному переходу</p>
            <h2>Сильный семейный проект часто теряет ценность, когда о нём говорят слишком общими девелоперскими словами</h2>
            <p>
              Если показывать «Дома у сада» просто как современный семейный жилой комплекс с благоустройством и хорошей локацией,
              коммуникация остаётся в категории обычных рыночных обещаний. Но если раскрыть проект через реальный job семьи,
              ценность становится конкретнее: меньше трения, больше воздуха, больше устойчивости на годы вперёд.
            </p>
          </div>

          <div class="compare745">
            {comparisons.map((item) => (
              <article class="compare745__card">
                <p class="compare745__overline">{item.overline}</p>
                <h3>{item.title}</h3>
                <p>{item.text}</p>
              </article>
            ))}
          </div>

          <div class="life745__grid">
            {lifeStages.map((item) => (
              <article class="life745__card">
                <p class="life745__stage">{item.stage}</p>
                <p class="life745__price">{item.price}</p>
                <p>{item.who}</p>
                <p><strong>Что на самом деле нанимают:</strong> {item.hire}</p>
                <p><strong>Формат:</strong> {item.format}</p>
              </article>
            ))}
          </div>
        </div>
      </section>

      <section class="process745 section section--dark">
        <div class="container">
          <div class="section745-heading center745 section745-heading--light">
            <h2>Как может выглядеть переупаковка проекта под реальный job семьи</h2>
          </div>
          <div class="process745__grid">
            {processSteps.map((step) => (
              <article class="process745__card">
                <span class="process745__number">{step.number}</span>
                <h3>{step.title}</h3>
                <p>{step.text}</p>
              </article>
            ))}
          </div>
        </div>
      </section>

      <section class="final745 section" id="contact">
        <div class="container final745__grid">
          <div class="final745__content">
            <div class="section745-heading">
              <p class="section745-heading__eyebrow">Точка входа в переупаковку</p>
              <h2>Если хотите, мы можем показать, как могла бы выглядеть более сильная упаковка ЖК «Дома у сада» под реальный семейный job</h2>
              <p>
                На примере текущего позиционирования проекта можно быстро увидеть, какие сильные стороны уже есть у ЖК,
                какие из них недораскрыты и как их можно превратить в более точный оффер, страницу и воронку коммуникации.
              </p>
            </div>

            <form class="form745" name={formName} method="POST" data-netlify="true" netlify-honeypot="bot-field">
              <input type="hidden" name="form-name" value={formName} />
              <input type="hidden" name="bot-field" />
              <input type="hidden" name="offer" value="offer801" />
              <input type="hidden" name="project" value="doma-u-sada" />
              <input type="hidden" name="developer" value="ak-bars-dom" />
              <input type="hidden" name="templateBase" value="offer-745" />
              <label>
                <span>Имя</span>
                <input type="text" name="name" required />
              </label>
              <label>
                <span>Телефон или Telegram</span>
                <input type="text" name="contact" required />
              </label>
              <label>
                <span>Ссылка на проект или комментарий</span>
                <textarea name="comment" rows="4"></textarea>
              </label>
              <button class="button745 button745--primary" type="submit">Показать вариант переупаковки проекта</button>
            </form>
          </div>

          <div class="final745__visual">
            <img src={images.currentPositioning} alt="Текущее позиционирование ЖК Дома у сада" loading="lazy" />
            <p class="final745__caption">Текущее позиционирование проекта — как точка входа в переупаковку</p>
          </div>
        </div>
      </section>
    </main>
  </body>
</html>
