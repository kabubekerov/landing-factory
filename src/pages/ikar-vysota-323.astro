---
import Analytics from '../components/Analytics.astro';
import '../styles/global.css';

const slug = 'ikar-vysota-323';
const formName = `landing-${slug}`;

const images = {
  hero: '/assets/stay-but-grow/original/hero_hero.jpg',
  aha1: '/assets/stay-but-grow/original/aha1_lobby.jpg',
  aha2: '/assets/stay-but-grow/original/aha2_view.jpg',
  aha3: '/assets/stay-but-grow/original/aha3_space.jpg',
  qualifier: '/assets/stay-but-grow/original/qualifier_who.jpg',
  compare: '/assets/stay-but-grow/original/aha1_lobby.jpg',
  evolution: '/assets/stay-but-grow/original/aha2_view.jpg',
  footer: '/assets/stay-but-grow/original/footer_cta.jpg',
  currentPositioning: '/assets/ikar-vysota-323/original/current_positioning.webp',
};

const triggerPoints = [
  'Есть этап, когда человеку больше не нужно доказывать себе, что он может расти. Работа, доход, круг общения и внутренний масштаб уже изменились.',
  'Но среда повседневной жизни по-прежнему остаётся на уровне прошлого этапа: случайный дом, устаревший формат, пространство без ощущения зрелости.',
  'Город стал по-настоящему своим, но дом внутри него всё ещё не отражает того, кем человек уже стал.',
];

const responseCards = [
  {
    number: '01',
    title: 'Адрес, который соответствует уровню',
    problem: '«Я давно вырос из этого района, но всё откладываю переезд — кажется, что это сложно и требует начинать всё заново».',
    answer:
      'Высота 323 — это не переезд в другой город и не разрыв с привычным. Это переход на более высокий уровень жизни внутри Челябинска, который уже стал своим.',
    detail:
      'Центральная локация, бизнес-класс, 30 этажей с видовыми квартирами. Адрес, который читается без объяснений.',
    cta: 'Посмотреть, как это решение может быть упаковано для вашего ЖК',
    image: images.aha1,
    alt: 'Статусное лобби с приглушённым светом и взрослым характером',
  },
  {
    number: '02',
    title: 'Среда, которая усиливает',
    problem: '«Я возвращаюсь домой и чувствую, что пространство вокруг не соответствует тому, кем я стал. Это незаметно, но давит».',
    answer:
      'Лобби, общие пространства, архитектура фасада и качество среды внутри — всё это работает как ежедневное подтверждение уровня. Не декор, а ощущение.',
    detail:
      'Атриум, продуманные общие зоны, современная инженерия. Среда, которая не требует объяснений — она просто считывается.',
    cta: 'Обсудить, как среда проекта работает как аргумент продажи',
    image: images.aha2,
    alt: 'Вид из панорамного окна на ночной Челябинск с высоты',
  },
  {
    number: '03',
    title: 'Рост без разрыва',
    problem:
      '«Я не хочу терять свой город, маршруты, связи и привычный ритм. Но хочу жить иначе — лучше, взрослее, точнее».',
    answer:
      'Не нужно уезжать в другой город или менять всё разом. Высота 323 — это способ вырасти внутри своей городской биографии, не отказываясь от неё.',
    detail:
      'Челябинск, ул. Братьев Каширины / Каслинская. Центр. Сдача — IV квартал 2028. Всё, что уже стало своим — остаётся.',
    cta: 'Если в вашем проекте есть ценность, которую рынок не считывает — обсудим переупаковку',
    image: images.aha3,
    alt: 'Просторная квартира с панорамным видом на город вечером',
  },
];

const selfSelection = [
  'Когда уровень жизни вырос, а пространство вокруг — ещё нет.',
  'Когда хочется жить иначе, но не уезжать из своего города.',
  'Когда компромисс с жильём стал ощущаться как тихая потеря качества.',
];

const comparisons = [
  {
    overline: 'Против «статусных» ЖК',
    title: 'Взрослый уровень без кричащей роскоши',
    text: 'Высота 323 — не про демонстрацию. Про среду, архитектуру и ощущение собранности, которое не нужно объяснять.',
  },
  {
    overline: 'Против старого фонда',
    title: 'Городская биография — без устаревшей инфраструктуры',
    text: 'Привычный Челябинск, знакомые маршруты и связи — но на качественно другом уровне повседневного опыта.',
  },
  {
    overline: 'Против массовой застройки',
    title: 'Бизнес-класс как норма, а не исключение',
    text: 'Продуманная архитектура, достойные общие пространства и приватность — не как бонус, а как базовый стандарт.',
  },
];

const lifeStages = [
  {
    stage: 'Первый переход',
    price: 'Бизнес-класс',
    who: 'Вы живёте в привычном районе, но уровень жизни уже вырос. Пора привести среду в соответствие.',
    hire: 'Пространство, которое усиливает самоощущение — без переезда в другой город.',
    format: '1- и 2-комнатные с видовыми характеристиками. Вход в новый уровень.',
  },
  {
    stage: 'Взрослый адрес',
    price: 'Бизнес-класс',
    who: 'Вы хотите жить в центре, в доме с характером — без компромиссов с инфраструктурой и окружением.',
    hire: 'Адрес, который считывается. Среда, которая соответствует.',
    format: '2- и 3-комнатные. Центральная локация. Собранный образ жизни.',
  },
  {
    stage: 'Городская зрелость',
    price: 'Бизнес-класс',
    who: 'Вы всё доказали. Хотите дом, в котором уровень жизни виден без слов — через архитектуру, вид и среду.',
    hire: 'Пространство над городом. Приватность. Ощущение, что жизнь наконец собрана.',
    format: 'Видовые квартиры верхних этажей. Высота 323 — Челябинск.',
  },
  {
    stage: 'Личная территория',
    price: 'Бизнес-класс',
    who: 'Вы цените абсолютную приватность и хотите, чтобы дом был вашей крепостью — видовой, закрытой, неповторимой.',
    hire: 'Собственное пространство над городом, где никто не смотрит в ваши окна.',
    format: 'Видовые квартиры верхних этажей. Только для тех, кто уже дома.',
  },
];

const processSteps = [
  {
    number: '01',
    title: 'Вы оставляете контакты и ссылку на проект',
    text: 'Показываете текущий ЖК, лендинг или рекламную коммуникацию, которая не даёт нужной конверсии.',
  },
  {
    number: '02',
    title: 'Мы собираем гипотезу переупаковки',
    text: 'Смотрим сегмент, JTBD-напряжение, текущий оффер и архитектуру страницы, чтобы найти, где именно теряются продажи.',
  },
  {
    number: '03',
    title: 'Проводим встречу по проекту',
    text: 'Показываем, как может выглядеть более точное позиционирование, структура лендинга и конверсионная логика без банальных штампов.',
  },
  {
    number: '04',
    title: 'Фиксируем следующий шаг',
    text: 'Определяем, что именно нужно делать дальше: корректировать сегмент, перепрошивать оффер или полностью пересобирать упаковку проекта.',
  },
];
---

<html lang="ru">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>ЖК «Высота 323» — Жить на новом уровне в своём городе</title>
    <meta
      name="description"
      content="ЖК Высота 323 от ГК ИКАР — бизнес-класс в центре Челябинска для тех, кто хочет вырасти внутри своего города."
    />
  </head>
  <body class="landing-745">
    <Analytics landingSlug={slug} />

    <main>
      <section class="hero745 section section--photo-hero">
        <div class="hero745__backdrop" style={`--section-bg: url(${images.hero})`}></div>
        <div class="container hero745__container">
          <div class="hero745__label">ЖК «Высота 323» · Челябинск · Центр · ГК ИКАР</div>
          <div class="hero745__grid">
            <div class="hero745__content hero745__content--glass">
              <h1>Жить на новом уровне — <em>не уезжая из своего города.</em></h1>
              <p class="hero745__lead">
                Когда жизнь уже выросла, особенно важно, чтобы ей соответствовали дом, адрес, ритм и среда вокруг.
                Высота 323 — это способ перейти в более высокий класс городской жизни, сохранив всё, что уже стало своим.
              </p>
              <p class="hero745__offer-line">Бизнес-класс · 30 этажей · Центр Челябинска · Сдача — IV квартал 2028</p>
              <div class="hero745__actions hero745__actions--stacked">
                <a class="button745 button745--primary" href="#contact">Ознакомиться с предложением</a>
              </div>
            </div>

            <aside class="hero745__card hero745__card--floating">
              <div class="hero745__card-body">
                <h2>Бизнес-класс в центре Челябинска для тех, кто хочет вырасти внутри своего города</h2>
                <p class="hero745__meta">Центр · Бизнес-класс · 30 этажей · IV квартал 2028</p>
                <p>
                  Архитектура, приватность, локация и качество общих пространств делают городской рост
                  естественным продолжением жизни, а не вынужденным разрывом с привычным.
                </p>
              </div>
            </aside>
          </div>
        </div>
      </section>

      <section class="section section--tight triggers745-wrap triggers745-wrap--hero-continued">
        <div class="hero745__backdrop hero745__backdrop--continued" style={`--section-bg: url(${images.hero})`}></div>
        <div class="triggers745__tone"></div>
        <div class="container triggers745__container">
          <div class="triggers745">
            {triggerPoints.map((item) => <p>{item}</p>)}
          </div>
        </div>
      </section>

      <section class="immersive745 immersive745--hero" style={`--immersive-bg: url(${images.aha1})`}>
        <div class="container immersive745__inner">
          <div class="immersive745__card">
            <p class="immersive745__eyebrow">Высота 323 · ГК ИКАР · Челябинск</p>
            <h2>Чтобы вырасти, не обязательно начинать жизнь заново</h2>
            <p>
              Есть другой сценарий. Не переезжать ради перемены как таковой, а перейти в более высокий класс городской жизни,
              сохранив всё, что уже стало своим: город, привычные маршруты, связи, ритм и ощущение принадлежности.
            </p>
            <div class="immersive745__facts">
              <span>Бизнес-класс</span>
              <span>Центр Челябинска</span>
              <span>30 этажей</span>
              <span>Сдача — IV квартал 2028</span>
            </div>
          </div>
        </div>
      </section>

      <section class="section responses745 section--photo-soft" style={`--section-bg: url(${images.aha2})`}>
        <div class="responses745__veil"></div>
        <div class="container responses745__container">
          <div class="section745-heading center745 section745-heading--light">
            <h2>Как Высота 323 отвечает на то, что вас останавливало</h2>
          </div>
          <div class="responses745__stack">
            {responseCards.map((card) => (
              <article class="response745-card">
                <div class="response745-card__media">
                  <img src={card.image} alt={card.alt} loading="lazy" />
                </div>
                <div class="response745-card__body">
                  <div class="response745-card__number">{card.number}</div>
                  <h3>{card.title}</h3>
                  <p class="response745-card__problem">{card.problem}</p>
                  <p>{card.answer}</p>
                  <p class="response745-card__detail">{card.detail}</p>
                  {card.cta && (
                    <a class="inline-link745" href="#contact">{card.cta}</a>
                  )}
                </div>
              </article>
            ))}
          </div>
        </div>
      </section>

      <section class="split-photo745">
        <div class="split-photo745__image" style={`--split-bg: url(${images.qualifier})`}></div>
        <div class="split-photo745__content-wrap">
          <div class="container split-photo745__container">
            <div class="split-photo745__content">
              <p class="immersive745__eyebrow">Высота 323 · Узнайте себя</p>
              <h2>Этот дом — для тех, кто готов занять более взрослое место в своём городе</h2>
              <div class="self745 self745--transparent">
                {selfSelection.map((item) => <p>{item}</p>)}
              </div>
                <blockquote class="quote745 quote745--light">
                <p>
                  «Высота 323 — это редкий пример проекта, где архитектура и среда работают как аргумент сами по себе.
                  Не нужно объяснять уровень — он считывается с первого взгляда».
                </p>
                <footer>ГК ИКАР · Челябинск</footer>
              </blockquote>
              <a class="inline-link745 inline-link745--light" href="#contact">Если ваш продукт сильнее, чем его текущая упаковка — обсудим это на встрече</a>
            </div>
          </div>
        </div>
      </section>

      <section class="immersive745 immersive745--contrast" style={`--immersive-bg: url(${images.aha3})`}>
        <div class="container immersive745__inner immersive745__inner--right">
          <div class="immersive745__card immersive745__card--single-story">
            <div class="story745-card">
              <div class="story745-card__number">03</div>
              <h2>Рост без разрыва</h2>
              <p class="story745-card__problem">«Я не хочу терять свой город, маршруты, связи и привычный ритм. Но хочу жить иначе — лучше, взрослее, точнее».</p>
              <p>Высота 323 — это не переезд в другой город. Это способ вырасти внутри своей городской биографии, не отказываясь от неё. Новый дом, центральная локация, бизнес-класс — и всё, что уже стало своим, остаётся.</p>
              <a class="inline-link745" href="#contact">Если у вашего проекта есть ценность, которую рынок пока не считывает — давайте это разберём</a>
            </div>
          </div>
        </div>
      </section>

      <section class="section life745 section--photo-soft" style={`--section-bg: url(${images.evolution})`}>
        <div class="responses745__veil responses745__veil--warm"></div>
        <div class="container life745__container">
          <div class="section745-heading center745 section745-heading--light section745-heading--max">
            <h2>На каком этапе своей эволюции клиент выбирает Высоту 323?</h2>
            <p>Эта таблица показывает не ассортимент, а логику того, как сегмент, жизненная ситуация и Core Job соединяются в осмысленное позиционирование.</p>
          </div>
          <div class="life745-table-wrap">
            <table class="life745-table">
              <thead>
                <tr>
                  <th>Этап</th>
                  <th>Кто вы сейчас</th>
                  <th>Что вы нанимаете</th>
                  <th>Формат в Высоте 323</th>
                </tr>
              </thead>
              <tbody>
                {lifeStages.map((item) => (
                  <tr>
                    <td>
                      <strong>{item.stage}</strong>
                      <span>{item.price}</span>
                    </td>
                    <td>{item.who}</td>
                    <td>{item.hire}</td>
                    <td>{item.format}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
          <div class="center745 action745-wrap">
            <a class="button745 button745--ghost" href="#contact">Обсудить, как упаковать ваш ЖК под сценарий жизни клиента</a>
          </div>
        </div>
      </section>

      <section class="section process745 section--photo-band" style={`--section-bg: url(${images.footer})`}>
        <div class="section-band745__overlay section-band745__overlay--dark"></div>
        <div class="container process745__container">
          <div class="section745-heading center745 section745-heading--light section745-heading--max">
            <h2>Как проходит путь к переупаковке девелоперского продукта</h2>
          </div>
          <div class="process745__grid process745__grid--stacked">
            {processSteps.map((step) => (
              <article class="process745-card process745-card--light process745-card--stacked">
                <div class="process745-card__number">{step.number}</div>
                <h3>{step.title}</h3>
                <p>{step.text}</p>
              </article>
            ))}
          </div>
        </div>
      </section>

      <section id="contact" class="section final745 final745--photo">
        <div class="final745__backdrop" style={`--final-bg: url(${images.footer})`}></div>
        <div class="container final745__container">
          <div class="final745__layout">
            <div class="final745__media-copy">
              <p class="final745__eyebrow">Текущее позиционирование ЖК «Высота 323»</p>
              <h2>Если текущее позиционирование не приводит к продажам — оставьте контакты, и мы проведём встречу, где расскажем про наш подход</h2>
              <p class="final745__lead final745__lead--light">
                Покажем, как можно переупаковать ваш ЖК через сегмент, JTBD и структуру страницы, которая помогает продавать, а не просто нравиться.
              </p>
              <div class="final745__positioning-shot">
                <img src={images.currentPositioning} alt="Пример текущего позиционирования проекта девелопера" loading="lazy" />
              </div>
            </div>
            <div class="final745__card">
              <h3 class="final745__form-title" style="color: #1a1a1a; font-size: 1.5rem; margin-bottom: 0.5rem;">Стратегическая встреча по переупаковке</h3>
              <p class="final745__lead">Оставьте контакты — проведём встречу и расскажем про наш подход</p>
              <p class="final745__lead">
                Разберём текущее позиционирование проекта и покажем, как может выглядеть новая упаковка лендинга и оффера.
              </p>
              <form
                name={formName}
                method="POST"
                data-netlify="true"
                netlify-honeypot="bot-field"
                action="/thank-you"
                class="final745__form"
              >
                <input type="hidden" name="form-name" value={formName} />
                <input type="hidden" name="landing_slug" value={slug} />
                <input type="hidden" name="utm_source" value="" />
                <input type="hidden" name="utm_medium" value="" />
                <input type="hidden" name="utm_campaign" value="" />
                <input type="hidden" name="utm_content" value="" />
                <input type="hidden" name="utm_term" value="" />

                <p class="sr-only">
                  <label>
                    Не заполняйте это поле, если вы человек:
                    <input name="bot-field" />
                  </label>
                </p>

                <div class="final745__form-grid">
                  <div class="final745__field-block">
                    <label for="name" class="field-label745">Имя</label>
                    <input type="text" id="name" name="name" required class="field-input745" />
                  </div>

                  <div class="final745__field-block final745__form-full">
                    <label for="phone" class="field-label745">Телефон / Telegram</label>
                    <input type="tel" id="phone" name="phone" required class="field-input745" />
                  </div>

                  <div class="final745__field-block final745__form-full">
                    <label for="email" class="field-label745">Email</label>
                    <input type="email" id="email" name="email" required class="field-input745" />
                  </div>


                </div>

                <button type="submit" class="button745 button745--primary final745__submit">
                  Записаться на встречу
                </button>
                <p class="final745__submit-note">Если текущее позиционирование не приводит к продажам — оставьте контакты, мы проведём встречу.</p>
              </form>
            </div>
          </div>
        </div>
      </section>
    </main>

    <script define:vars={{ slug }}>
      import { populateUTMFields, trackFormSubmission } from '../utils/analytics.ts';

      const form = document.querySelector('#contact form');

      if (form instanceof HTMLFormElement) {
        populateUTMFields(form);
        form.addEventListener('submit', () => {
          populateUTMFields(form);
          trackFormSubmission(slug);
        });
      }
    </script>
  </body>
</html>

<style>
  :global(body.landing-745) {
    background: #130f0d;
    color: #241b16;
  }

  .landing-745 main {
    overflow-x: hidden;
    background: #f6efe8;
  }

  .section {
    position: relative;
  }

  .hero745,
  .life745,
  .final745,
  .responses745,
  .process745 {
